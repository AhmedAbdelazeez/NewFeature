@page
@model NewFeature.Pages.OperationalAuditsModel
@{
    ViewData["Title"] = "Internal Audit - Operational Analysis";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="glow-text"><i class="bi bi-shield-check me-2"></i> <span data-i18n="operationalaudits-title">Internal Audit - Operational Analysis</span></h1>
            <p class="text-muted mb-0" data-i18n="operationalaudits-subtitle">Manage operational process audits, track critical findings, and monitor risk mitigation</p>
        </div>
        <button class="btn btn-neon" onclick="openAddModal()">
            <i class="bi bi-plus-circle me-1"></i> <span data-i18n="operationalaudits-btn-add">Add Operational Audit</span>
        </button>
    </div>

    <!-- Search Toolbar -->
    <div class="glass-card mb-4 p-3">
        <div class="row align-items-center g-3">
            <div class="col-12">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-glass text-muted"><i class="bi bi-search"></i></span>
                    <input type="text" id="auditSearch" class="form-control form-control-glass" placeholder="Search audits by title, department, status..." onkeyup="filterAudits()">
                </div>
            </div>
        </div>
    </div>

    <!-- Audits Table -->
    <div class="glass-card">
        <div class="table-responsive">
            <table class="table table-glass text-white align-middle" id="auditsTable">
                <thead>
                    <tr>
                        <th data-i18n="operationalaudits-th-title">Audit Title</th>
                        <th data-i18n="operationalaudits-th-dept">Department</th>
                        <th data-i18n="operationalaudits-th-date">Audit Date</th>
                        <th data-i18n="operationalaudits-th-audited">Audited Processes</th>
                        <th data-i18n="operationalaudits-th-passed">Passed Processes</th>
                        <th data-i18n="operationalaudits-th-critical">Critical Findings</th>
                        <th data-i18n="operationalaudits-th-recommendations">Recommendations</th>
                        <th data-i18n="operationalaudits-th-mitigation">Risk Mitigation Rate</th>
                        <th data-i18n="operationalaudits-th-status">Status</th>
                        <th data-i18n="operationalaudits-th-actions" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody id="auditsList">
                    <tr>
                        <td colspan="10" class="text-center py-4 text-muted"><i class="bi bi-arrow-repeat spin me-2"></i> Loading audits...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add/Edit Operational Audit Glass Modal -->
<div class="modal fade" id="auditModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content modal-content-glass">
            <div class="modal-header modal-header-glass">
                <h5 class="modal-title glow-text" id="modalTitle" data-i18n="operationalaudits-btn-add">Add Operational Audit</h5>
                <button type="button" class="close-btn-glass" data-bs-dismiss="modal" aria-label="Close">&times;</button>
            </div>
            <form id="auditForm" onsubmit="saveAudit(event)">
                <div class="modal-body p-4">
                    <input type="hidden" id="auditId">
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="titleEn" class="form-label" data-i18n="operationalaudits-lbl-title-en">Audit Title (EN)</label>
                            <input type="text" id="titleEn" class="form-control form-control-glass" required>
                        </div>
                        <div class="col-md-6">
                            <label for="titleAr" class="form-label" data-i18n="operationalaudits-lbl-title-ar">Audit Title (AR)</label>
                            <input type="text" id="titleAr" class="form-control form-control-glass" required>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="departmentId" class="form-label" data-i18n="operationalaudits-lbl-dept">Department</label>
                            <select id="departmentId" class="form-control form-control-glass" required>
                                <option value="">Select Department</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="auditDate" class="form-label" data-i18n="operationalaudits-lbl-date">Audit Date</label>
                            <input type="date" id="auditDate" class="form-control form-control-glass" required>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="auditedProcessCount" class="form-label" data-i18n="operationalaudits-lbl-audited">Audited Processes Count</label>
                            <input type="number" id="auditedProcessCount" class="form-control form-control-glass" min="1" required oninput="validatePassedCount()">
                        </div>
                        <div class="col-md-6">
                            <label for="passedProcessCount" class="form-label" data-i18n="operationalaudits-lbl-passed">Passed Processes Count</label>
                            <input type="number" id="passedProcessCount" class="form-control form-control-glass" min="0" required oninput="validatePassedCount()">
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label for="criticalFindingsCount" class="form-label" data-i18n="operationalaudits-lbl-critical">Critical Findings Count</label>
                            <input type="number" id="criticalFindingsCount" class="form-control form-control-glass" min="0" required>
                        </div>
                        <div class="col-md-4">
                            <label for="recommendationsCount" class="form-label" data-i18n="operationalaudits-lbl-recommendations">Recommendations Count</label>
                            <input type="number" id="recommendationsCount" class="form-control form-control-glass" min="0" required>
                        </div>
                        <div class="col-md-4">
                            <label for="riskMitigationRate" class="form-label" data-i18n="operationalaudits-lbl-mitigation">Risk Mitigation Rate (%)</label>
                            <input type="number" step="0.1" id="riskMitigationRate" class="form-control form-control-glass" min="0" max="100" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="status" class="form-label" data-i18n="operationalaudits-lbl-status">Audit Status</label>
                        <select id="status" class="form-control form-control-glass" required>
                            <option value="0">Planned</option>
                            <option value="1">In Progress</option>
                            <option value="2">Completed</option>
                            <option value="3">Follow Up</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer modal-footer-glass">
                    <button type="button" class="btn btn-neon-outline" data-bs-dismiss="modal" data-i18n="btn-cancel">Cancel</button>
                    <button type="submit" class="btn btn-neon" data-i18n="btn-save">Save Audit</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const currentLang = localStorage.getItem('lang') || 'en';
        let audits = [];
        let departments = [];

        const statusLabels = {
            0: { text: "Planned", class: "badge-glow-info" },
            1: { text: "In Progress", class: "badge-glow-warning" },
            2: { text: "Completed", class: "badge-glow-success" },
            3: { text: "Follow Up", class: "badge-glow-danger" }
        };

        const statusLabelsAr = {
            0: { text: "مخطط", class: "badge-glow-info" },
            1: { text: "قيد التنفيذ", class: "badge-glow-warning" },
            2: { text: "مكتمل", class: "badge-glow-success" },
            3: { text: "متابعة", class: "badge-glow-danger" }
        };

        document.addEventListener("DOMContentLoaded", async function () {
            await loadDepartments();
            await loadAudits();
        });

        async function loadDepartments() {
            try {
                const res = await fetch('/api/compliance/departments');
                if (res.ok) {
                    departments = await res.json();
                    const dropdown = document.getElementById("departmentId");
                    dropdown.innerHTML = currentLang === 'en' 
                        ? '<option value="">Select Department</option>' 
                        : '<option value="">اختر الإدارة</option>';
                    departments.forEach(d => {
                        const name = currentLang === 'en' ? d.nameEn : d.nameAr;
                        dropdown.innerHTML += `<option value="${d.id}">${name}</option>`;
                    });
                }
            } catch (err) {
                console.error("Error loading departments:", err);
            }
        }

        async function loadAudits() {
            try {
                const res = await fetch('/api/operationalaudits', {
                    headers: {
                        'Accept-Language': currentLang
                    }
                });
                if (res.ok) {
                    audits = await res.json();
                    renderAudits();
                }
            } catch (err) {
                console.error("Error loading audits:", err);
            }
        }

        function renderAudits() {
            const tbody = document.getElementById("auditsList");
            tbody.innerHTML = "";

            if (audits.length === 0) {
                tbody.innerHTML = currentLang === 'en'
                    ? `<tr><td colspan="10" class="text-center text-muted">No operational audits found.</td></tr>`
                    : `<tr><td colspan="10" class="text-center text-muted">لم يتم العثور على عمليات تدقيق تشغيلية.</td></tr>`;
                return;
            }

            audits.forEach(a => {
                const title = currentLang === 'en' ? a.titleEn : a.titleAr;
                const statusMeta = currentLang === 'en' ? statusLabels[a.status] : statusLabelsAr[a.status];
                const badge = `<span class="${statusMeta.class}">${statusMeta.text}</span>`;
                const date = new Date(a.auditDate).toLocaleDateString(currentLang === 'en' ? 'en-US' : 'ar-SA');

                const tr = document.createElement("tr");
                tr.innerHTML = `
                    <td><strong>${title}</strong></td>
                    <td>${a.departmentName}</td>
                    <td>${date}</td>
                    <td><span class="badge badge-glow-info">${a.auditedProcessCount}</span></td>
                    <td><span class="badge badge-glow-success">${a.passedProcessCount}</span></td>
                    <td><span class="badge ${a.criticalFindingsCount > 0 ? 'badge-glow-danger' : 'badge-glow-success'}">${a.criticalFindingsCount}</span></td>
                    <td><span class="badge badge-glow-warning">${a.recommendationsCount}</span></td>
                    <td><span class="text-neon font-semibold">${a.riskMitigationRate}%</span></td>
                    <td>${badge}</td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-1 flex-nowrap">
                            <button class="btn btn-neon-outline btn-sm" onclick="editAudit(${a.id})" title="Edit"><i class="bi bi-pencil-square"></i></button>
                            <button class="btn btn-neon-danger btn-sm" onclick="deleteAudit(${a.id})" title="Delete"><i class="bi bi-trash"></i></button>
                        </div>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function filterAudits() {
            const query = document.getElementById("auditSearch").value.toLowerCase();
            const rows = document.querySelectorAll("#auditsList tr");

            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                if (text.includes(query)) {
                    row.style.display = "";
                } else {
                    row.style.display = "none";
                }
            });
        }

        function validatePassedCount() {
            const audited = parseInt(document.getElementById("auditedProcessCount").value) || 0;
            const passedInput = document.getElementById("passedProcessCount");
            const passed = parseInt(passedInput.value) || 0;
            if (passed > audited) {
                passedInput.setCustomValidity(currentLang === 'en' 
                    ? "Passed processes cannot exceed audited processes." 
                    : "العمليات السليمة لا يمكن أن تتجاوز العمليات المفحوصة.");
            } else {
                passedInput.setCustomValidity("");
            }
        }

        function openAddModal() {
            document.getElementById("auditForm").reset();
            document.getElementById("auditId").value = "";
            document.getElementById("modalTitle").setAttribute("data-i18n", "operationalaudits-btn-add");
            document.getElementById("modalTitle").innerText = currentLang === 'en' ? "Add Operational Audit" : "إضافة تدقيق تشغيلي";
            
            const modal = new bootstrap.Modal(document.getElementById('auditModal'));
            modal.show();
        }

        async function editAudit(id) {
            try {
                const res = await fetch(`/api/operationalaudits/${id}`, {
                    headers: { 'Accept-Language': currentLang }
                });
                if (res.ok) {
                    const a = await res.json();
                    document.getElementById("auditId").value = a.id;
                    document.getElementById("titleEn").value = a.titleEn;
                    document.getElementById("titleAr").value = a.titleAr;
                    document.getElementById("departmentId").value = a.departmentId;
                    document.getElementById("auditDate").value = a.auditDate.substring(0, 10);
                    document.getElementById("auditedProcessCount").value = a.auditedProcessCount;
                    document.getElementById("passedProcessCount").value = a.passedProcessCount;
                    document.getElementById("criticalFindingsCount").value = a.criticalFindingsCount;
                    document.getElementById("recommendationsCount").value = a.recommendationsCount;
                    document.getElementById("riskMitigationRate").value = a.riskMitigationRate;
                    document.getElementById("status").value = a.status;

                    document.getElementById("modalTitle").removeAttribute("data-i18n");
                    document.getElementById("modalTitle").innerText = currentLang === 'en' ? "Edit Operational Audit" : "تعديل تدقيق تشغيلي";

                    const modal = new bootstrap.Modal(document.getElementById('auditModal'));
                    modal.show();
                }
            } catch (err) {
                console.error("Error fetching audit:", err);
            }
        }

        async function saveAudit(event) {
            event.preventDefault();
            validatePassedCount();
            if (!document.getElementById("auditForm").checkValidity()) {
                document.getElementById("auditForm").reportValidity();
                return;
            }

            const id = document.getElementById("auditId").value;
            const dto = {
                id: id ? parseInt(id) : 0,
                titleEn: document.getElementById("titleEn").value,
                titleAr: document.getElementById("titleAr").value,
                departmentId: parseInt(document.getElementById("departmentId").value),
                auditDate: new Date(document.getElementById("auditDate").value).toISOString(),
                auditedProcessCount: parseInt(document.getElementById("auditedProcessCount").value),
                passedProcessCount: parseInt(document.getElementById("passedProcessCount").value),
                criticalFindingsCount: parseInt(document.getElementById("criticalFindingsCount").value),
                recommendationsCount: parseInt(document.getElementById("recommendationsCount").value),
                riskMitigationRate: parseFloat(document.getElementById("riskMitigationRate").value),
                status: parseInt(document.getElementById("status").value)
            };

            const url = id ? `/api/operationalaudits/${id}` : '/api/operationalaudits';
            const method = id ? 'PUT' : 'POST';

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(dto)
                });

                if (res.ok) {
                    const modalEl = document.getElementById('auditModal');
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    if (modal) modal.hide();
                    await loadAudits();
                } else {
                    const errorData = await res.json();
                    alert("Error saving: " + JSON.stringify(errorData));
                }
            } catch (err) {
                console.error("Error saving audit:", err);
            }
        }

        async function deleteAudit(id) {
            const confirmMsg = currentLang === 'en'
                ? "Are you sure you want to delete this operational audit?"
                : "هل أنت متأكد من رغبتك في حذف هذا التدقيق التشغيلي؟";
            if (!confirm(confirmMsg)) return;

            try {
                const res = await fetch(`/api/operationalaudits/${id}`, {
                    method: 'DELETE'
                });
                if (res.ok) {
                    await loadAudits();
                }
            } catch (err) {
                console.error("Error deleting audit:", err);
            }
        }
    </script>
}
