        function toggleLanguage() {
            const currentLang = localStorage.getItem('lang') === 'ar' ? 'en' : 'ar';
            localStorage.setItem('lang', currentLang);
            document.cookie = "lang=" + currentLang + ";path=/;max-age=31536000";
            location.reload();
        }

        function applyLanguage(lang) {
            document.documentElement.setAttribute('lang', lang);
            document.documentElement.setAttribute('dir', lang === 'ar' ? 'rtl' : 'ltr');
            
            const btnText = document.getElementById('langToggleText');
            if (btnText) {
                btnText.innerText = lang === 'en' ? 'العربية (AR)' : 'English (EN)';
            }

            // Translate elements marked with data-i18n
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (translations[lang] && translations[lang][key]) {
                    if (el.tagName === 'INPUT' && (el.type === 'button' || el.type === 'submit')) {
                        el.value = translations[lang][key];
                    } else if (el.tagName === 'INPUT' && el.placeholder) {
                        el.placeholder = translations[lang][key];
                    } else {
                        el.innerText = translations[lang][key];
                    }
                }
            });
        }

        (function() {
            const lang = localStorage.getItem('lang') || 'ar';
            applyLanguage(lang);

            // Intercept global fetch requests to automatically append request headers
            const originalFetch = window.fetch;
            window.fetch = function(input, init) {
                init = init || {};
                init.headers = init.headers || {};
                const currentLang = localStorage.getItem('lang') || 'ar';
                
                if (init.headers instanceof Headers) {
                    init.headers.set('X-Language', currentLang);
                    init.headers.set('Accept-Language', currentLang);
                } else if (Array.isArray(init.headers)) {
                    init.headers.push(['X-Language', currentLang]);
                    init.headers.push(['Accept-Language', currentLang]);
                } else {
                    init.headers['X-Language'] = currentLang;
                    init.headers['Accept-Language'] = currentLang;
                }
                return originalFetch(input, init);
            };
        })();

        // Page Transition Loader Logic
        document.addEventListener('DOMContentLoaded', () => {
            // Hide loader when page is fully loaded
            window.addEventListener('load', () => {
                const loader = document.getElementById('page-transition-loader');
                if (loader) {
                    loader.classList.add('loader-hidden');
                }
            });

            // Show loader when clicking on navigation links
            document.querySelectorAll('a:not([target="_blank"]):not([href^="#"]):not([href^="javascript:"])').forEach(link => {
                link.addEventListener('click', function (e) {
                    // Don't show loader for default prevented events or new tabs
                    if (e.defaultPrevented || e.ctrlKey || e.metaKey || e.shiftKey) return;
                    
                    const href = this.getAttribute('href');
                    if (href && href !== '#' && href !== window.location.pathname) {
                        const loader = document.getElementById('page-transition-loader');
                        if (loader) {
                            loader.classList.remove('loader-hidden');
                        }
                    }
                });
            });

            // Ensure loader is hidden if page is shown from back/forward cache
            window.addEventListener('pageshow', (event) => {
                if (event.persisted) {
                    const loader = document.getElementById('page-transition-loader');
                    if (loader) {
                        loader.classList.add('loader-hidden');
                    }
                }
            });
            
            // Fallback: hide loader after 3 seconds just in case 'load' event doesn't fire
            setTimeout(() => {
                const loader = document.getElementById('page-transition-loader');
                if (loader && !loader.classList.contains('loader-hidden')) {
                    loader.classList.add('loader-hidden');
                }
            }, 3000);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
