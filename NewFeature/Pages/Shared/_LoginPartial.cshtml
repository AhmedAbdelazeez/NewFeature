@using Microsoft.AspNetCore.Identity
@using NewFeature.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    var currentUser = await UserManager.GetUserAsync(User);
    var dispName = currentUser?.FullNameEn ?? User.Identity?.Name;
    <li class="nav-item">
        <span class="nav-link nav-link-custom me-3"><i class="bi bi-person-circle"></i> Hello, <span class="glow-text">@dispName</span>!</span>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
            <button type="submit" class="btn btn-neon-outline btn-sm py-1 px-3">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="btn btn-neon btn-sm py-1 px-3" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
}
</ul>
