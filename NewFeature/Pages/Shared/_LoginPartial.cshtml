@using Microsoft.AspNetCore.Identity
@using NewFeature.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    var currentUser = await UserManager.GetUserAsync(User);
    var currentLang = Context.Request.Cookies["lang"] ?? "en";
    var dispName = currentLang == "ar" ? (currentUser?.FullNameAr ?? currentUser?.FullNameEn) : (currentUser?.FullNameEn ?? currentUser?.FullNameAr);
    <li class="nav-item">
        <span class="nav-link nav-link-custom me-3">
            <i class="bi bi-person-circle"></i> 
            <span data-i18n="nav-hello">Hello</span>, <span class="glow-text">@dispName</span>!
        </span>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
            <button type="submit" class="btn btn-neon-outline btn-sm py-1 px-3" data-i18n="btn-logout">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="btn btn-neon btn-sm py-1 px-3" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
}
</ul>
