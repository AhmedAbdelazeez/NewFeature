@page
@model IndexModel
@{
    ViewData["Title"] = "Enterprise Dashboard";
}

<div class="py-4">
    <div class="text-center mb-5">
        <h1 data-i18n="dashboard-title" class="display-4 fw-extrabold mb-2" style="font-family: var(--font-outfit); background: linear-gradient(135deg, var(--brand-gold) 0%, var(--brand-gold-light) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
            RAWAHEL AL MASHAER CO
        </h1>
        <p data-i18n="dashboard-subtitle" class="text-muted fs-5">شركة رواحل المشاعر — Enterprise Portal</p>
        <hr class="border-glass w-25 mx-auto">
    </div>

    <div class="row g-4 justify-content-center">
        <!-- 1. Project Management Card -->
        <div class="col-md-6 col-lg-4">
            <a href="/Projects" class="text-decoration-none">
                <div class="glass-card h-100 d-flex flex-column justify-content-between">
                    <div>
                        <div class="fs-1 mb-3" style="color: var(--brand-gold);"><i class="bi bi-kanban"></i></div>
                        <h3 data-i18n="card-projects-title">Project Management</h3>
                        <p data-i18n="card-projects-desc" class="text-muted mt-2">Oversee client projects, milestones, tasks, dependencies, and resources</p>
                    </div>
                    <div class="mt-4 text-end">
                        <span data-i18n="card-projects-btn" class="btn btn-neon-outline btn-sm">Manage Projects →</span>
                    </div>
                </div>
            </a>
        </div>

        <!-- 2. Fleet Management Card -->
        <div class="col-md-6 col-lg-4">
            <a href="/Fleet" class="text-decoration-none">
                <div class="glass-card h-100 d-flex flex-column justify-content-between">
                    <div>
                        <div class="fs-1 mb-3" style="color: var(--brand-gold);"><i class="bi bi-truck"></i></div>
                        <h3 data-i18n="card-fleet-title">Fleet Management</h3>
                        <p data-i18n="card-fleet-desc" class="text-muted mt-2">Manage vehicle assets, check maintenance status, license plates, and capacities</p>
                    </div>
                    <div class="mt-4 text-end">
                        <span data-i18n="card-fleet-btn" class="btn btn-neon-outline btn-sm">Manage Fleet →</span>
                    </div>
                </div>
            </a>
        </div>

        <!-- 3. Client Management Card -->
        <div class="col-md-6 col-lg-4">
            <a href="/Clients" class="text-decoration-none">
                <div class="glass-card h-100 d-flex flex-column justify-content-between">
                    <div>
                        <div class="fs-1 mb-3" style="color: var(--brand-gold);"><i class="bi bi-briefcase"></i></div>
                        <h3 data-i18n="card-clients-title">Client Management</h3>
                        <p data-i18n="card-clients-desc" class="text-muted mt-2">Register client accounts, set identification codes, and update contact info</p>
                    </div>
                    <div class="mt-4 text-end">
                        <span data-i18n="card-clients-btn" class="btn btn-neon-outline btn-sm">Manage Clients →</span>
                    </div>
                </div>
            </a>
        </div>

        <!-- 4. Compliance Department Card -->
        <div class="col-md-6 col-lg-4">
            <a href="/Compliance" class="text-decoration-none">
                <div class="glass-card h-100 d-flex flex-column justify-content-between">
                    <div>
                        <div class="fs-1 mb-3" style="color: var(--brand-gold);"><i class="bi bi-shield-check"></i></div>
                        <h3 data-i18n="card-compliance-title">Compliance Department</h3>
                        <p data-i18n="card-compliance-desc" class="text-muted mt-2">Monitor compliance KPIs, track violations, log internal audits, and manage improvements</p>
                    </div>
                    <div class="mt-4 text-end">
                        <span data-i18n="card-compliance-btn" class="btn btn-neon-outline btn-sm">Manage Compliance →</span>
                    </div>
                </div>
            </a>
        </div>

        <!-- 5. Internal Audit Card -->
        <div class="col-md-6 col-lg-4">
            <a href="/OperationalAudits" class="text-decoration-none">
                <div class="glass-card h-100 d-flex flex-column justify-content-between">
                    <div>
                        <div class="fs-1 mb-3" style="color: var(--brand-gold);"><i class="bi bi-shield-check"></i></div>
                        <h3 data-i18n="card-operational-title">Internal Audit - Operational Analysis</h3>
                        <p data-i18n="card-operational-desc" class="text-muted mt-2">Manage operational process audits, track critical findings, and monitor risk mitigation</p>
                    </div>
                    <div class="mt-4 text-end">
                        <span data-i18n="card-operational-btn" class="btn btn-neon-outline btn-sm">Manage Audits →</span>
                    </div>
                </div>
            </a>
        </div>

        <!-- 6. Human Resources Card -->
        <div class="col-md-6 col-lg-4">
            <a href="/Employees" class="text-decoration-none">
                <div class="glass-card h-100 d-flex flex-column justify-content-between">
                    <div>
                        <div class="fs-1 mb-3" style="color: var(--brand-gold);"><i class="bi bi-people"></i></div>
                        <h3 data-i18n="card-hr-title">Human Resources</h3>
                        <p data-i18n="card-hr-desc" class="text-muted mt-2">Manage employee lists, assign roles, track performance ratings, and record evaluations</p>
                    </div>
                    <div class="mt-4 text-end">
                        <span data-i18n="card-hr-btn" class="btn btn-neon-outline btn-sm">Manage HR →</span>
                    </div>
                </div>
            </a>
        </div>

        <!-- 7. IT Department Card -->
        <div class="col-md-6 col-lg-4">
            <a href="/It" class="text-decoration-none">
                <div class="glass-card h-100 d-flex flex-column justify-content-between">
                    <div>
                        <div class="fs-1 mb-3" style="color: var(--brand-gold);"><i class="bi bi-laptop"></i></div>
                        <h3 data-i18n="card-it-title">IT Department</h3>
                        <p data-i18n="card-it-desc" class="text-muted mt-2">Manage IT support tickets, track systems uptime, monitor backups, and automation rates</p>
                    </div>
                    <div class="mt-4 text-end">
                        <span data-i18n="card-it-btn" class="btn btn-neon-outline btn-sm">Manage IT →</span>
                    </div>
                </div>
            </a>
        </div>

        <!-- 8. HSE Department Card -->
        <div class="col-md-6 col-lg-4">
            <a href="/Hse" class="text-decoration-none">
                <div class="glass-card h-100 d-flex flex-column justify-content-between">
                    <div>
                        <div class="fs-1 mb-3" style="color: var(--brand-gold);"><i class="bi bi-shield-exclamation"></i></div>
                        <h3 data-i18n="card-hse-title">HSE Department</h3>
                        <p data-i18n="card-hse-desc" class="text-muted mt-2">Manage safety incidents, log near-misses, track safety inspections, and training hours</p>
                    </div>
                    <div class="mt-4 text-end">
                        <span data-i18n="card-hse-btn" class="btn btn-neon-outline btn-sm">Manage HSE →</span>
                    </div>
                </div>
            </a>
        </div>

        <!-- 9. Procurement Card -->
        <div class="col-md-6 col-lg-4">
            <a href="/Procurement" class="text-decoration-none">
                <div class="glass-card h-100 d-flex flex-column justify-content-between">
                    <div>
                        <div class="fs-1 mb-3" style="color: var(--brand-gold);"><i class="bi bi-cart-check"></i></div>
                        <h3 data-i18n="card-procurement-title">Procurement & Support</h3>
                        <p data-i18n="card-procurement-desc" class="text-muted mt-2">Manage purchase requests, track supplier performance, monitor spare parts and inventory</p>
                    </div>
                    <div class="mt-4 text-end">
                        <span data-i18n="card-procurement-btn" class="btn btn-neon-outline btn-sm">Manage Procurement →</span>
                    </div>
                </div>
            </a>
        </div>

        <!-- 10. Strategy & Performance Card -->
        <div class="col-md-6 col-lg-4">
            <a href="/Strategy" class="text-decoration-none">
                <div class="glass-card h-100 d-flex flex-column justify-content-between">
                    <div>
                        <div class="fs-1 mb-3" style="color: var(--brand-gold);"><i class="bi bi-bar-chart-line"></i></div>
                        <h3 data-i18n="card-strategy-title">Strategy & Performance</h3>
                        <p data-i18n="card-strategy-desc" class="text-muted mt-2">Manage long-term strategic goals, track PMO initiatives, and monitor governance maturity</p>
                    </div>
                    <div class="mt-4 text-end">
                        <span data-i18n="card-strategy-btn" class="btn btn-neon-outline btn-sm">Manage Strategy →</span>
                    </div>
                </div>
            </a>
        </div>

        <!-- 11. Finance Department Card -->
        <div class="col-md-6 col-lg-4">
            <a href="/Finance" class="text-decoration-none">
                <div class="glass-card h-100 d-flex flex-column justify-content-between">
                    <div>
                        <div class="fs-1 mb-3" style="color: var(--brand-gold);"><i class="bi bi-cash-coin"></i></div>
                        <h3 data-i18n="card-finance-title">Finance Department</h3>
                        <p data-i18n="card-finance-desc" class="text-muted mt-2">Manage financial transactions, cash flows, and monitor department-allocated budgets</p>
                    </div>
                    <div class="mt-4 text-end">
                        <span data-i18n="card-finance-btn" class="btn btn-neon-outline btn-sm">Manage Finance →</span>
                    </div>
                </div>
            </a>
        </div>

        <!-- 12. Commercial Department Card -->
        <div class="col-md-6 col-lg-4">
            <a href="/Commercial" class="text-decoration-none">
                <div class="glass-card h-100 d-flex flex-column justify-content-between">
                    <div>
                        <div class="fs-1 mb-3" style="color: var(--brand-gold);"><i class="bi bi-briefcase-fill"></i></div>
                        <h3 data-i18n="card-commercial-title">Commercial Department</h3>
                        <p data-i18n="card-commercial-desc" class="text-muted mt-2">Manage commercial B2B contracts, follow up on leads, and track retention rates</p>
                    </div>
                    <div class="mt-4 text-end">
                        <span data-i18n="card-commercial-btn" class="btn btn-neon-outline btn-sm">Manage Commercial →</span>
                    </div>
                </div>
            </a>
        </div>

        <!-- 13. Tourism Department Card -->
        <div class="col-md-6 col-lg-4">
            <a href="/Tourism" class="text-decoration-none">
                <div class="glass-card h-100 d-flex flex-column justify-content-between">
                    <div>
                        <div class="fs-1 mb-3" style="color: var(--brand-gold);"><i class="bi bi-compass"></i></div>
                        <h3 data-i18n="card-tourism-title">Tourism Department</h3>
                        <p data-i18n="card-tourism-desc" class="text-muted mt-2">Manage hotel bookings, tourist program tours, and itineraries for pilgrims</p>
                    </div>
                    <div class="mt-4 text-end">
                        <span data-i18n="card-tourism-btn" class="btn btn-neon-outline btn-sm">Manage Tourism →</span>
                    </div>
                </div>
            </a>
        </div>

        <!-- 14. Operations Department Card -->
        <div class="col-md-6 col-lg-4">
            <a href="/Operations" class="text-decoration-none">
                <div class="glass-card h-100 d-flex flex-column justify-content-between">
                    <div>
                        <div class="fs-1 mb-3" style="color: var(--brand-gold);"><i class="bi bi-gear-wide-connected"></i></div>
                        <h3 data-i18n="card-operations-title">Operations Department</h3>
                        <p data-i18n="card-operations-desc" class="text-muted mt-2">Monitor daily dispatching plans, operational schedules, and manage fleet incidents</p>
                    </div>
                    <div class="mt-4 text-end">
                        <span data-i18n="card-operations-btn" class="btn btn-neon-outline btn-sm">Manage Operations →</span>
                    </div>
                </div>
            </a>
        </div>

        <!-- 15. User Directory & Settings Card (Admins Only) -->
        @if (User.IsInRole("Admin"))
        {
            <div class="col-md-6 col-lg-4">
                <a href="/Users" class="text-decoration-none">
                    <div class="glass-card h-100 d-flex flex-column justify-content-between">
                        <div>
                            <div class="fs-1 mb-3" style="color: var(--brand-gold);"><i class="bi bi-shield-lock"></i></div>
                            <h3 data-i18n="card-users-title">User Directory & Settings</h3>
                            <p data-i18n="card-users-desc" class="text-muted mt-2">Manage personnel profiles, toggle active status, and assign security roles</p>
                        </div>
                        <div class="mt-4 text-end">
                            <span data-i18n="card-users-btn" class="btn btn-neon-outline btn-sm">Manage Users →</span>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>
