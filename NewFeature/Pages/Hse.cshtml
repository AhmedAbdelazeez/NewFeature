@page
@model HseModel
@{
    ViewData["Title"] = "HSE Department Management";
}

<div class="py-4">
    <!-- Header Area -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6 fw-extrabold glow-text mb-1" data-i18n="hse-title" style="font-family: var(--font-outfit);">الصحة والسلامة والبيئة</h1>
            <p class="text-muted fs-6 mb-0" data-i18n="hse-subtitle">إدارة الحوادث والسلامة المهنية، جولات التفتيش الوقائي، ونسب الامتثال والتدريب</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-neon" onclick="openAddIncidentModal()" data-i18n="hse-btn-add-incident">تسجيل حادث جديد</button>
            <button class="btn btn-neon-outline" onclick="openAddInspectionModal()" data-i18n="hse-btn-add-inspection">إضافة تفتيش جديد</button>
        </div>
    </div>

    <!-- Tabs Navigation -->
    <ul class="nav nav-tabs nav-tabs-glass mb-4" id="hseTabs" role="tabpanel">
        <li class="nav-item">
            <button class="nav-link active" id="incidents-tab" data-bs-toggle="tab" data-bs-target="#incidents-tab-content" type="button" role="tab" aria-selected="true" data-i18n="tab-hse-incidents">سجل الحوادث والسلامة</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="inspections-tab" data-bs-toggle="tab" data-bs-target="#inspections-tab-content" type="button" role="tab" aria-selected="false" data-i18n="tab-hse-inspections">التفتيش الوقائي والامتثال</button>
        </li>
    </ul>

    <!-- Tab Contents -->
    <div class="tab-content" id="hseTabsContent">
        
        <!-- Tab 1: HSE Incidents -->
        <div class="tab-pane fade show active" id="incidents-tab-content" role="tabpanel" aria-labelledby="incidents-tab">
            <div class="glass-card mb-4 p-3">
                <div class="row align-items-center g-3">
                    <div class="col-md-9">
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-glass text-muted"><i class="bi bi-search"></i></span>
                            <input type="text" id="incidentSearch" class="form-control form-control-glass" placeholder="البحث في الحوادث..." onkeyup="filterIncidents()">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <select id="incidentTypeFilter" class="form-control form-control-glass" onchange="filterIncidents()">
                            <option value="" data-i18n="opt-all-types">كل الأنواع</option>
                            <option value="Injury" data-i18n="opt-type-injury">إصابة عمل (Injury)</option>
                            <option value="SeriousAccident" data-i18n="opt-type-accident">حادث جسيم (Serious Accident)</option>
                            <option value="NearMiss" data-i18n="opt-type-nearmiss">حادث وشيك (Near-Miss)</option>
                            <option value="Environmental" data-i18n="opt-type-environmental">بيئي (Environmental)</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="glass-card">
                <div class="table-responsive">
                    <table class="table table-glass text-white align-middle" id="incidentsTable">
                        <thead>
                            <tr>
                                <th data-i18n="hse-th-title">الحادث</th>
                                <th data-i18n="hse-th-type">النوع</th>
                                <th data-i18n="hse-th-severity">الخطورة</th>
                                <th data-i18n="hse-th-date">التاريخ</th>
                                <th data-i18n="hse-th-location">الموقع</th>
                                <th data-i18n="hse-th-actions" class="text-end">الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody id="incidentsList">
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted"><i class="bi bi-arrow-repeat spin me-2"></i> جاري تحميل الحوادث...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Tab 2: HSE Inspections -->
        <div class="tab-pane fade" id="inspections-tab-content" role="tabpanel" aria-labelledby="inspections-tab">
            <div class="glass-card mb-4 p-3">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-glass text-muted"><i class="bi bi-search"></i></span>
                    <input type="text" id="inspectionSearch" class="form-control form-control-glass" placeholder="البحث في جولات التفتيش..." onkeyup="filterInspections()">
                </div>
            </div>

            <div class="glass-card">
                <div class="table-responsive">
                    <table class="table table-glass text-white align-middle" id="inspectionsTable">
                        <thead>
                            <tr>
                                <th data-i18n="hse-th-insp-title">الجولة التفتيشية</th>
                                <th data-i18n="hse-th-insp-inspector">المفتش</th>
                                <th data-i18n="hse-th-insp-date">التاريخ</th>
                                <th data-i18n="hse-th-insp-score">درجة الامتثال</th>
                                <th data-i18n="hse-th-insp-hours">ساعات التدريب</th>
                                <th data-i18n="hse-th-insp-status">الحالة</th>
                                <th data-i18n="hse-th-actions" class="text-end">الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody id="inspectionsList">
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted"><i class="bi bi-arrow-repeat spin me-2"></i> جاري تحميل جولات التفتيش...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal 1: Add/Edit Incident -->
<div class="modal fade" id="incidentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content modal-content-glass">
            <div class="modal-header modal-header-glass">
                <h5 class="modal-title glow-text" id="incidentModalTitle" data-i18n="hse-modal-title-add-incident">تسجيل حادث جديد</h5>
                <button type="button" class="close-btn-glass" data-bs-dismiss="modal" aria-label="Close">&times;</button>
            </div>
            <form id="incidentForm" onsubmit="saveIncident(event)">
                <div class="modal-body p-4">
                    <input type="hidden" id="incidentId">
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="incidentTitleEn" class="form-label" data-i18n="hse-lbl-title-en">عنوان الحادث (English)</label>
                            <input type="text" id="incidentTitleEn" class="form-control form-control-glass" required>
                        </div>
                        <div class="col-md-6">
                            <label for="incidentTitleAr" class="form-label" data-i18n="hse-lbl-title-ar">عنوان الحادث (عربي)</label>
                            <input type="text" id="incidentTitleAr" class="form-control form-control-glass" required>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="incidentDescriptionEn" class="form-label" data-i18n="hse-lbl-desc-en">التفاصيل (English)</label>
                            <textarea id="incidentDescriptionEn" class="form-control form-control-glass" rows="3"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label for="incidentDescriptionAr" class="form-label" data-i18n="hse-lbl-desc-ar">التفاصيل (عربي)</label>
                            <textarea id="incidentDescriptionAr" class="form-control form-control-glass" rows="3"></textarea>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="incidentType" class="form-label" data-i18n="hse-lbl-type">النوع</label>
                            <select id="incidentType" class="form-control form-control-glass" required>
                                <option value="NearMiss">حادث وشيك (Near-Miss)</option>
                                <option value="Injury">إصابة عمل (Injury)</option>
                                <option value="SeriousAccident">حادث جسيم (Serious Accident)</option>
                                <option value="Environmental">بيئي (Environmental)</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="incidentSeverity" class="form-label" data-i18n="hse-lbl-severity">مستوى الخطورة</label>
                            <select id="incidentSeverity" class="form-control form-control-glass" required>
                                <option value="Low">Low</option>
                                <option value="Medium" selected>Medium</option>
                                <option value="High">High</option>
                                <option value="Critical">Critical</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="incidentDate" class="form-label" data-i18n="hse-lbl-date">تاريخ الحادث</label>
                            <input type="date" id="incidentDate" class="form-control form-control-glass" required>
                        </div>
                        <div class="col-md-6">
                            <label for="incidentLocation" class="form-label" data-i18n="hse-lbl-location">الموقع / الحافلة</label>
                            <input type="text" id="incidentLocation" class="form-control form-control-glass" required>
                        </div>
                    </div>
                </div>
                <div class="modal-footer modal-footer-glass">
                    <button type="button" class="btn btn-neon-outline" data-bs-dismiss="modal" data-i18n="btn-cancel">إلغاء</button>
                    <button type="submit" class="btn btn-neon" data-i18n="btn-save">حفظ التغييرات</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal 2: Add/Edit Inspection -->
<div class="modal fade" id="inspectionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content modal-content-glass">
            <div class="modal-header modal-header-glass">
                <h5 class="modal-title glow-text" id="inspectionModalTitle" data-i18n="hse-modal-title-add-inspection">إضافة تفتيش جديد</h5>
                <button type="button" class="close-btn-glass" data-bs-dismiss="modal" aria-label="Close">&times;</button>
            </div>
            <form id="inspectionForm" onsubmit="saveInspection(event)">
                <div class="modal-body p-4">
                    <input type="hidden" id="inspectionId">
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="inspTitleEn" class="form-label" data-i18n="hse-lbl-insp-title-en">عنوان الجولة (English)</label>
                            <input type="text" id="inspTitleEn" class="form-control form-control-glass" required>
                        </div>
                        <div class="col-md-6">
                            <label for="inspTitleAr" class="form-label" data-i18n="hse-lbl-insp-title-ar">عنوان الجولة (عربي)</label>
                            <input type="text" id="inspTitleAr" class="form-control form-control-glass" required>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="inspInspector" class="form-label" data-i18n="hse-lbl-insp-inspector">اسم المفتش</label>
                            <input type="text" id="inspInspector" class="form-control form-control-glass" required>
                        </div>
                        <div class="col-md-6">
                            <label for="inspDate" class="form-label" data-i18n="hse-lbl-insp-date">تاريخ التفتيش</label>
                            <input type="date" id="inspDate" class="form-control form-control-glass" required>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label for="inspScore" class="form-label" data-i18n="hse-lbl-insp-score">درجة الامتثال (%)</label>
                            <input type="number" step="0.1" min="0" max="100" id="inspScore" class="form-control form-control-glass" value="100.0" required>
                        </div>
                        <div class="col-md-4">
                            <label for="inspHours" class="form-label" data-i18n="hse-lbl-insp-hours">ساعات التدريب المنفذة</label>
                            <input type="number" step="0.5" min="0" id="inspHours" class="form-control form-control-glass" value="0.0" required>
                        </div>
                        <div class="col-md-4">
                            <label for="inspStatus" class="form-label" data-i18n="hse-lbl-insp-status">الحالة</label>
                            <select id="inspStatus" class="form-control form-control-glass" required>
                                <option value="Planned">Planned</option>
                                <option value="Completed" selected>Completed</option>
                                <option value="Cancelled">Cancelled</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer modal-footer-glass">
                    <button type="button" class="btn btn-neon-outline" data-bs-dismiss="modal" data-i18n="btn-cancel">إلغاء</button>
                    <button type="submit" class="btn btn-neon" data-i18n="btn-save">حفظ التغييرات</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let incidents = [];
        let inspections = [];

        document.addEventListener("DOMContentLoaded", () => {
            loadIncidents();
            loadInspections();
        });

        // ───────── Incidents Fetch & Render ─────────
        async function loadIncidents() {
            try {
                const res = await fetch("/api/hse/incidents");
                if (res.ok) {
                    incidents = await res.json();
                    renderIncidents(incidents);
                }
            } catch (err) {
                console.error("Error loading incidents:", err);
            }
        }

        function renderIncidents(list) {
            const listContainer = document.getElementById("incidentsList");
            const isAr = document.documentElement.lang === 'ar';
            listContainer.innerHTML = "";

            if (list.length === 0) {
                listContainer.innerHTML = `<tr><td colspan="6" class="text-center py-4 text-muted" data-i18n="hse-empty-incidents">لا توجد حوادث مسجلة حالياً</td></tr>`;
                return;
            }

            list.forEach(i => {
                const title = isAr ? i.titleAr : i.titleEn;
                const dateStr = new Date(i.date).toLocaleDateString(isAr ? 'ar-EG' : 'en-US');
                
                let severityClass = 'badge-glow-info';
                if (i.severity === 'High') severityClass = 'badge-glow-danger';
                if (i.severity === 'Critical') severityClass = 'badge-glow-danger';

                let typeClass = 'badge-glow-info';
                if (i.type === 'Injury' || i.type === 'SeriousAccident') typeClass = 'badge-glow-danger';
                if (i.type === 'NearMiss') typeClass = 'badge-glow-success';

                listContainer.innerHTML += `
                    <tr>
                        <td><strong>${title}</strong></td>
                        <td><span class="badge ${typeClass}">${i.type}</span></td>
                        <td><span class="badge ${severityClass}">${i.severity}</span></td>
                        <td class="font-mono text-muted text-sm">${dateStr}</td>
                        <td>${i.location || '—'}</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-neon-outline" onclick="editIncident(${i.id})"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-neon-outline" onclick="deleteIncident(${i.id})"><i class="bi bi-trash"></i></button>
                            </div>
                        </td>
                    </tr>`;
            });
        }

        function filterIncidents() {
            const query = document.getElementById("incidentSearch").value.toLowerCase();
            const typeFilter = document.getElementById("incidentTypeFilter").value;
            const isAr = document.documentElement.lang === 'ar';

            const filtered = incidents.filter(i => {
                const title = isAr ? i.titleAr : i.titleEn;
                const description = isAr ? i.descriptionAr : i.descriptionEn;
                const matchesQuery = title.toLowerCase().includes(query) || (description && description.toLowerCase().includes(query));
                const matchesType = !typeFilter || i.type === typeFilter;
                return matchesQuery && matchesType;
            });

            renderIncidents(filtered);
        }

        // ───────── Inspections Fetch & Render ─────────
        async function loadInspections() {
            try {
                const res = await fetch("/api/hse/inspections");
                if (res.ok) {
                    inspections = await res.json();
                    renderInspections(inspections);
                }
            } catch (err) {
                console.error("Error loading inspections:", err);
            }
        }

        function renderInspections(list) {
            const listContainer = document.getElementById("inspectionsList");
            const isAr = document.documentElement.lang === 'ar';
            listContainer.innerHTML = "";

            if (list.length === 0) {
                listContainer.innerHTML = `<tr><td colspan="7" class="text-center py-4 text-muted" data-i18n="hse-empty-inspections">لا توجد جولات تفتيشية مسجلة حالياً</td></tr>`;
                return;
            }

            list.forEach(ins => {
                const title = isAr ? ins.titleAr : ins.titleEn;
                const dateStr = new Date(ins.inspectionDate).toLocaleDateString(isAr ? 'ar-EG' : 'en-US');
                
                let statusClass = 'badge-glow-info';
                if (ins.status === 'Completed') statusClass = 'badge-glow-success';
                if (ins.status === 'Cancelled') statusClass = 'badge-glow-danger';

                listContainer.innerHTML += `
                    <tr>
                        <td><strong>${title}</strong></td>
                        <td>${ins.inspectorName}</td>
                        <td class="font-mono text-muted text-sm">${dateStr}</td>
                        <td class="font-mono font-bold text-neon">${ins.complianceScore.toFixed(1)}%</td>
                        <td class="font-mono font-bold">${ins.trainingHours.toFixed(1)} ساعة</td>
                        <td><span class="badge ${statusClass}">${ins.status}</span></td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-neon-outline" onclick="editInspection(${ins.id})"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-neon-outline" onclick="deleteInspection(${ins.id})"><i class="bi bi-trash"></i></button>
                            </div>
                        </td>
                    </tr>`;
            });
        }

        function filterInspections() {
            const query = document.getElementById("inspectionSearch").value.toLowerCase();
            const isAr = document.documentElement.lang === 'ar';
            const filtered = inspections.filter(ins => {
                const title = isAr ? ins.titleAr : ins.titleEn;
                return title.toLowerCase().includes(query) || ins.inspectorName.toLowerCase().includes(query);
            });
            renderInspections(filtered);
        }

        // ───────── Incident Modals / CRUD ─────────
        function openAddIncidentModal() {
            document.getElementById("incidentForm").reset();
            document.getElementById("incidentId").value = '';
            document.getElementById("incidentDate").value = new Date().toISOString().split('T')[0];

            document.getElementById("incidentModalTitle").setAttribute("data-i18n", "hse-modal-title-add-incident");
            if (typeof applyLanguage === "function") {
                applyLanguage(localStorage.getItem('lang') || 'en');
            }

            const modal = new bootstrap.Modal(document.getElementById("incidentModal"));
            modal.show();
        }

        async function editIncident(id) {
            try {
                const res = await fetch(`/api/hse/incidents/${id}`);
                if (res.ok) {
                    const i = await res.json();
                    document.getElementById("incidentId").value = i.id;
                    document.getElementById("incidentTitleEn").value = i.titleEn;
                    document.getElementById("incidentTitleAr").value = i.titleAr;
                    document.getElementById("incidentDescriptionEn").value = i.descriptionEn || '';
                    document.getElementById("incidentDescriptionAr").value = i.descriptionAr || '';
                    document.getElementById("incidentType").value = i.type;
                    document.getElementById("incidentSeverity").value = i.severity;
                    document.getElementById("incidentDate").value = i.date.split('T')[0];
                    document.getElementById("incidentLocation").value = i.location || '';

                    document.getElementById("incidentModalTitle").setAttribute("data-i18n", "hse-modal-title-edit-incident");
                    if (typeof applyLanguage === "function") {
                        applyLanguage(localStorage.getItem('lang') || 'en');
                    }

                    const modal = new bootstrap.Modal(document.getElementById("incidentModal"));
                    modal.show();
                }
            } catch (err) {
                console.error("Error loading incident for edit:", err);
            }
        }

        async function saveIncident(event) {
            event.preventDefault();
            const id = document.getElementById("incidentId").value;
            
            const payload = {
                id: id ? parseInt(id) : 0,
                titleEn: document.getElementById("incidentTitleEn").value,
                titleAr: document.getElementById("incidentTitleAr").value,
                descriptionEn: document.getElementById("incidentDescriptionEn").value,
                descriptionAr: document.getElementById("incidentDescriptionAr").value,
                type: document.getElementById("incidentType").value,
                severity: document.getElementById("incidentSeverity").value,
                date: document.getElementById("incidentDate").value,
                location: document.getElementById("incidentLocation").value
            };

            const method = id ? 'PUT' : 'POST';
            const url = id ? `/api/hse/incidents/${id}` : '/api/hse/incidents';

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (res.ok) {
                    bootstrap.Modal.getInstance(document.getElementById("incidentModal")).hide();
                    loadIncidents();
                } else {
                    const err = await res.json();
                    alert(JSON.stringify(err));
                }
            } catch (err) {
                console.error("Error saving incident:", err);
            }
        }

        async function deleteIncident(id) {
            const isAr = document.documentElement.lang === 'ar';
            if (!confirm(isAr ? "هل أنت متأكد من حذف هذا البلاغ؟" : "Are you sure you want to delete this incident log?")) return;

            try {
                const res = await fetch(`/api/hse/incidents/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    loadIncidents();
                }
            } catch (err) {
                console.error("Error deleting incident:", err);
            }
        }

        // ───────── Inspection Modals / CRUD ─────────
        function openAddInspectionModal() {
            document.getElementById("inspectionForm").reset();
            document.getElementById("inspectionId").value = '';
            document.getElementById("inspDate").value = new Date().toISOString().split('T')[0];

            document.getElementById("inspectionModalTitle").setAttribute("data-i18n", "hse-modal-title-add-inspection");
            if (typeof applyLanguage === "function") {
                applyLanguage(localStorage.getItem('lang') || 'en');
            }

            const modal = new bootstrap.Modal(document.getElementById("inspectionModal"));
            modal.show();
        }

        async function editInspection(id) {
            try {
                const res = await fetch(`/api/hse/inspections/${id}`);
                if (res.ok) {
                    const ins = await res.json();
                    document.getElementById("inspectionId").value = ins.id;
                    document.getElementById("inspTitleEn").value = ins.titleEn;
                    document.getElementById("inspTitleAr").value = ins.titleAr;
                    document.getElementById("inspInspector").value = ins.inspectorName;
                    document.getElementById("inspDate").value = ins.inspectionDate.split('T')[0];
                    document.getElementById("inspScore").value = ins.complianceScore;
                    document.getElementById("inspHours").value = ins.trainingHours;
                    document.getElementById("inspStatus").value = ins.status;

                    document.getElementById("inspectionModalTitle").setAttribute("data-i18n", "hse-modal-title-edit-inspection");
                    if (typeof applyLanguage === "function") {
                        applyLanguage(localStorage.getItem('lang') || 'en');
                    }

                    const modal = new bootstrap.Modal(document.getElementById("inspectionModal"));
                    modal.show();
                }
            } catch (err) {
                console.error("Error loading inspection for edit:", err);
            }
        }

        async function saveInspection(event) {
            event.preventDefault();
            const id = document.getElementById("inspectionId").value;
            
            const payload = {
                id: id ? parseInt(id) : 0,
                titleEn: document.getElementById("inspTitleEn").value,
                titleAr: document.getElementById("inspTitleAr").value,
                inspectorName: document.getElementById("inspInspector").value,
                inspectionDate: document.getElementById("inspDate").value,
                complianceScore: parseFloat(document.getElementById("inspScore").value),
                trainingHours: parseFloat(document.getElementById("inspHours").value),
                status: document.getElementById("inspStatus").value
            };

            const method = id ? 'PUT' : 'POST';
            const url = id ? `/api/hse/inspections/${id}` : '/api/hse/inspections';

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (res.ok) {
                    bootstrap.Modal.getInstance(document.getElementById("inspectionModal")).hide();
                    loadInspections();
                } else {
                    const err = await res.json();
                    alert(JSON.stringify(err));
                }
            } catch (err) {
                console.error("Error saving inspection:", err);
            }
        }

        async function deleteInspection(id) {
            const isAr = document.documentElement.lang === 'ar';
            if (!confirm(isAr ? "هل أنت متأكد من حذف هذا التفتيش؟" : "Are you sure you want to delete this inspection?")) return;

            try {
                const res = await fetch(`/api/hse/inspections/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    loadInspections();
                }
            } catch (err) {
                console.error("Error deleting inspection:", err);
            }
        }
    </script>
}
