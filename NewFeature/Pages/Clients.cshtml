@page
@model NewFeature.Pages.ClientsModel
@{
    ViewData["Title"] = "Client Management";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="glow-text"><i class="bi bi-briefcase me-2"></i> <span data-i18n="clients-title">Client Management</span></h1>
            <p class="text-muted mb-0" data-i18n="clients-subtitle">Register client accounts, set identification codes, and update contact info</p>
        </div>
        <button class="btn btn-neon" onclick="openAddModal()">
            <i class="bi bi-plus-circle me-1"></i> <span data-i18n="clients-btn-add">Add New Client</span>
        </button>
    </div>

    <!-- Toolbar -->
    <div class="glass-card mb-4 p-3">
        <div class="row align-items-center g-3">
            <div class="col-12">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-glass text-muted"><i class="bi bi-search"></i></span>
                    <input type="text" id="clientSearch" class="form-control form-control-glass" placeholder="Search clients by name, code, email..." onkeyup="filterClients()">
                </div>
            </div>
        </div>
    </div>

    <!-- Clients Table -->
    <div class="glass-card">
        <div class="table-responsive">
            <table class="table table-glass text-white align-middle" id="clientsTable">
                <thead>
                    <tr>
                        <th data-i18n="clients-th-code">Client Code</th>
                        <th data-i18n="clients-th-name">Client Name</th>
                        <th data-i18n="clients-th-email">Email</th>
                        <th data-i18n="clients-th-phone">Phone</th>
                        <th data-i18n="clients-th-actions" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody id="clientsList">
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted"><i class="bi bi-arrow-repeat spin me-2"></i> Loading client listings...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add/Edit Client Glass Modal -->
<div class="modal fade" id="clientModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-glass">
            <div class="modal-header modal-header-glass">
                <h5 class="modal-title glow-text" id="modalTitle" data-i18n="clients-modal-title-add">Add Client</h5>
                <button type="button" class="close-btn-glass" data-bs-dismiss="modal" aria-label="Close">&times;</button>
            </div>
            <form id="clientForm" onsubmit="saveClient(event)">
                <div class="modal-body p-4">
                    <input type="hidden" id="clientId">
                    
                    <div class="mb-3">
                        <label for="code" class="form-label" data-i18n="clients-lbl-code">Client Code</label>
                        <input type="text" id="code" class="form-control form-control-glass" required>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="nameEn" class="form-label" data-i18n="clients-lbl-name-en">Client Name (EN)</label>
                            <input type="text" id="nameEn" class="form-control form-control-glass" required>
                        </div>
                        <div class="col-md-6">
                            <label for="nameAr" class="form-label" data-i18n="clients-lbl-name-ar">Client Name (AR)</label>
                            <input type="text" id="nameAr" class="form-control form-control-glass" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label" data-i18n="clients-lbl-email">Email Address</label>
                        <input type="email" id="email" class="form-control form-control-glass" required>
                    </div>

                    <div class="mb-3">
                        <label for="phone" class="form-label" data-i18n="clients-lbl-phone">Phone Number</label>
                        <input type="text" id="phone" class="form-control form-control-glass" required>
                    </div>
                </div>
                <div class="modal-footer modal-footer-glass">
                    <button type="button" class="btn btn-neon-outline" data-bs-dismiss="modal" data-i18n="btn-cancel">Cancel</button>
                    <button type="submit" class="btn btn-neon" data-i18n="btn-save">Save Client</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const currentLang = localStorage.getItem('lang') || 'en';
        let clients = [];

        document.addEventListener("DOMContentLoaded", function () {
            loadClients();
        });

        async function loadClients() {
            try {
                const res = await fetch('/api/clients');
                if (res.ok) {
                    clients = await res.json();
                    renderClients();
                }
            } catch (err) {
                console.error(err);
            }
        }

        function renderClients() {
            const tbody = document.getElementById("clientsList");
            tbody.innerHTML = "";

            if (clients.length === 0) {
                tbody.innerHTML = `<tr><td colspan="5" class="text-center text-muted">No clients found.</td></tr>`;
                return;
            }

            clients.forEach(c => {
                const name = c.name;

                const tr = document.createElement("tr");
                tr.innerHTML = `
                    <td><strong>${c.code}</strong></td>
                    <td>${name}</td>
                    <td>${c.email}</td>
                    <td>${c.phone}</td>
                    <td class="text-end">
                        <button class="btn btn-neon-outline btn-sm me-2" onclick="viewClientDetails(${c.id})"><i class="bi bi-eye"></i></button>
                        <button class="btn btn-neon-outline btn-sm me-2" onclick="editClient(${c.id})"><i class="bi bi-pencil-square"></i></button>
                        <button class="btn btn-neon-danger btn-sm" onclick="deleteClient(${c.id})"><i class="bi bi-trash"></i></button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function filterClients() {
            const query = document.getElementById("clientSearch").value.toLowerCase();
            const rows = document.querySelectorAll("#clientsList tr");

            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                if (text.includes(query)) {
                    row.style.display = "";
                } else {
                    row.style.display = "none";
                }
            });
        }

        function resetModalReadOnly(formId) {
            const form = document.getElementById(formId);
            form.querySelectorAll("input, select, textarea").forEach(el => el.disabled = false);
            const saveBtn = form.querySelector("button[type='submit']");
            if (saveBtn) saveBtn.style.display = "";
        }

        function openAddModal() {
            resetModalReadOnly("clientForm");
            document.getElementById("clientForm").reset();
            document.getElementById("clientId").value = "";
            document.getElementById("modalTitle").innerText = currentLang === 'en' ? "Add Client" : "إضافة عميل";
            
            const modal = new bootstrap.Modal(document.getElementById('clientModal'));
            modal.show();
        }

        async function editClient(id) {
            resetModalReadOnly("clientForm");
            try {
                const res = await fetch(`/api/clients/${id}`);
                if (res.ok) {
                    const c = await res.json();
                    document.getElementById("clientId").value = c.id;
                    document.getElementById("code").value = c.code;
                    document.getElementById("nameEn").value = c.nameEn;
                    document.getElementById("nameAr").value = c.nameAr;
                    document.getElementById("email").value = c.email;
                    document.getElementById("phone").value = c.phone;

                    document.getElementById("modalTitle").innerText = currentLang === 'en' ? "Edit Client Details" : "تعديل تفاصيل العميل";

                    const modal = new bootstrap.Modal(document.getElementById('clientModal'));
                    modal.show();
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function viewClientDetails(id) {
            await editClient(id);
            document.getElementById("modalTitle").innerText = currentLang === 'en' ? "Client Details" : "تفاصيل العميل";
            const form = document.getElementById("clientForm");
            form.querySelectorAll("input, select, textarea").forEach(el => el.disabled = true);
            const saveBtn = form.querySelector("button[type='submit']");
            if (saveBtn) saveBtn.style.display = "none";
        }

        async function saveClient(e) {
            e.preventDefault();

            const id = document.getElementById("clientId").value;
            const dto = {
                id: id ? parseInt(id) : 0,
                code: document.getElementById("code").value,
                nameEn: document.getElementById("nameEn").value,
                nameAr: document.getElementById("nameAr").value,
                email: document.getElementById("email").value,
                phone: document.getElementById("phone").value
            };

            const method = id ? 'PUT' : 'POST';
            const url = id ? `/api/clients/${id}` : '/api/clients';

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(dto)
                });

                if (res.ok) {
                    const modalEl = document.getElementById('clientModal');
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    modal.hide();
                    loadClients();
                } else {
                    alert("Error saving client.");
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function deleteClient(id) {
            const confirmMsg = currentLang === 'en' ? "Delete this client?" : "هل أنت متأكد من حذف هذا العميل؟";
            if (!confirm(confirmMsg)) return;

            try {
                const res = await fetch(`/api/clients/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    loadClients();
                } else {
                    alert("Failed to delete client.");
                }
            } catch (err) {
                console.error(err);
            }
        }
    </script>
}
