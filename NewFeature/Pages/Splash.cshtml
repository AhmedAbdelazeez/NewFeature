@page
@model NewFeature.Pages.SplashModel
@{
    Layout = null;
    ViewData["Title"] = "المنظومة الرقمية الموحدة";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --gold: #b0841a;
            --gold-light: #e2b34a;
            --gold-dark: #8c6510;
            --gold-glow: rgba(176, 132, 26, 0.6);
            --dark: #0a0a0f;
            --dark-blue: #0c1222;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background: var(--dark);
            overflow: hidden;
            width: 100vw;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* ═══════════════════════════════════════════
           BACKGROUND LAYERS
        ═══════════════════════════════════════════ */
        .splash-bg {
            position: fixed;
            inset: 0;
            z-index: 0;
        }

        /* Animated gradient mesh */
        .splash-bg::before {
            content: '';
            position: absolute;
            inset: 0;
            background:
                radial-gradient(ellipse 80% 60% at 50% 50%, rgba(176, 132, 26, 0.08) 0%, transparent 60%),
                radial-gradient(ellipse 40% 40% at 20% 80%, rgba(176, 132, 26, 0.05) 0%, transparent 50%),
                radial-gradient(ellipse 50% 30% at 80% 20%, rgba(226, 179, 74, 0.04) 0%, transparent 50%),
                linear-gradient(180deg, #060610 0%, #0c1222 40%, #0a0a15 100%);
            animation: bgPulse 8s ease-in-out infinite;
        }

        @@keyframes bgPulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.85; }
        }

        /* Grid overlay */
        .grid-overlay {
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(rgba(176, 132, 26, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(176, 132, 26, 0.03) 1px, transparent 1px);
            background-size: 60px 60px;
            animation: gridMove 20s linear infinite;
        }

        @@keyframes gridMove {
            0% { transform: translate(0, 0); }
            100% { transform: translate(60px, 60px); }
        }

        /* ═══════════════════════════════════════════
           PARTICLE CANVAS
        ═══════════════════════════════════════════ */
        #particleCanvas {
            position: fixed;
            inset: 0;
            z-index: 1;
            pointer-events: none;
        }

        /* ═══════════════════════════════════════════
           MAIN CONTENT
        ═══════════════════════════════════════════ */
        .splash-content {
            position: relative;
            z-index: 10;
            text-align: center;
            width: 100%;
            max-width: 900px;
            padding: 40px;
        }

        /* Logo Container */
        .logo-wrapper {
            position: relative;
            display: inline-block;
            margin-bottom: 40px;
            opacity: 0;
            transform: scale(0.3) rotateY(90deg);
            animation: logoReveal 1.8s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
        }

        @@keyframes logoReveal {
            0% { opacity: 0; transform: scale(0.3) rotateY(90deg); }
            60% { opacity: 1; transform: scale(1.1) rotateY(-5deg); }
            100% { opacity: 1; transform: scale(1) rotateY(0deg); }
        }

        .logo-ring {
            position: absolute;
            inset: -20px;
            border: 2px solid transparent;
            border-radius: 50%;
            border-top-color: var(--gold);
            border-right-color: var(--gold-light);
            animation: ringRotate 3s linear infinite;
        }

        .logo-ring:nth-child(2) {
            inset: -35px;
            border-top-color: var(--gold-light);
            border-bottom-color: var(--gold-dark);
            animation: ringRotate 4s linear infinite reverse;
        }

        .logo-ring:nth-child(3) {
            inset: -50px;
            border-left-color: rgba(176, 132, 26, 0.3);
            border-right-color: rgba(226, 179, 74, 0.3);
            animation: ringRotate 6s linear infinite;
        }

        @@keyframes ringRotate {
            to { transform: rotate(360deg); }
        }

        .logo-inner {
            width: 160px;
            height: 160px;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(255,255,255,0.95), rgba(250,249,246,0.95));
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow:
                0 0 30px var(--gold-glow),
                0 0 60px rgba(176, 132, 26, 0.2),
                inset 0 0 20px rgba(176, 132, 26, 0.05);
            position: relative;
            z-index: 2;
        }

        .logo-inner img {
            width: 110px;
            height: 110px;
            object-fit: contain;
            filter: drop-shadow(0 2px 8px rgba(176, 132, 26, 0.3));
        }

        /* Glow pulse behind logo */
        .logo-glow {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 250px;
            height: 250px;
            border-radius: 50%;
            background: radial-gradient(circle, var(--gold-glow) 0%, transparent 70%);
            animation: glowPulse 2.5s ease-in-out infinite;
            z-index: 0;
        }

        @@keyframes glowPulse {
            0%, 100% { opacity: 0.4; transform: translate(-50%, -50%) scale(1); }
            50% { opacity: 0.8; transform: translate(-50%, -50%) scale(1.3); }
        }

        /* ═══════════════════════════════════════════
           TYPOGRAPHY
        ═══════════════════════════════════════════ */

        /* Top decorative line */
        .deco-line {
            width: 0;
            height: 2px;
            margin: 0 auto 30px;
            background: linear-gradient(90deg, transparent, var(--gold), var(--gold-light), var(--gold), transparent);
            animation: lineExpand 1.5s ease-out 1.5s forwards;
            border-radius: 2px;
        }

        @@keyframes lineExpand {
            to { width: 300px; }
        }

        /* Main arabic title */
        .splash-title {
            font-size: clamp(2.2rem, 5vw, 4rem);
            font-weight: 900;
            line-height: 1.6;
            background: linear-gradient(135deg, var(--gold-light) 0%, var(--gold) 30%, #fff 50%, var(--gold) 70%, var(--gold-light) 100%);
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: shimmerText 3s linear infinite, fadeSlideUp 1.2s ease-out 2s both;
            margin-bottom: 15px;
            text-shadow: 0 0 40px rgba(176, 132, 26, 0.3);
        }

        @@keyframes shimmerText {
            to { background-position: 200% center; }
        }

        @@keyframes fadeSlideUp {
            from { opacity: 0; transform: translateY(40px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Company name */
        .company-name {
            font-size: clamp(1.2rem, 2.5vw, 1.8rem);
            font-weight: 700;
            color: rgba(226, 179, 74, 0.85);
            letter-spacing: 2px;
            animation: fadeSlideUp 1s ease-out 2.8s both;
            margin-bottom: 10px;
        }

        /* Subtitle */
        .splash-subtitle {
            font-size: clamp(1rem, 1.8vw, 1.3rem);
            color: rgba(255, 255, 255, 0.4);
            font-weight: 400;
            letter-spacing: 1px;
            animation: fadeSlideUp 1s ease-out 3.2s both;
        }

        /* Bottom deco line */
        .deco-line-bottom {
            width: 0;
            height: 1px;
            margin: 30px auto 0;
            background: linear-gradient(90deg, transparent, rgba(176, 132, 26, 0.4), transparent);
            animation: lineExpand2 1.5s ease-out 3.5s forwards;
        }

        @@keyframes lineExpand2 {
            to { width: 200px; }
        }

        /* ═══════════════════════════════════════════
           PROGRESS BAR
        ═══════════════════════════════════════════ */
        .progress-container {
            position: fixed;
            bottom: 60px;
            left: 50%;
            transform: translateX(-50%);
            width: min(600px, 85vw);
            z-index: 20;
            opacity: 0;
            animation: fadeSlideUp 0.8s ease-out 4s both;
        }

        .progress-label {
            display: flex;
            justify-content: space-between;
            margin-bottom: 15px;
            font-size: 1rem;
            color: rgba(226, 179, 74, 0.6);
            font-weight: 500;
            letter-spacing: 1px;
        }

        .progress-track {
            width: 100%;
            height: 6px;
            background: rgba(176, 132, 26, 0.12);
            border-radius: 4px;
            overflow: hidden;
            position: relative;
        }

        .progress-fill {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, var(--gold-dark), var(--gold), var(--gold-light));
            border-radius: 4px;
            transition: width 0.3s ease;
            position: relative;
        }

        .progress-fill::after {
            content: '';
            position: absolute;
            top: -4px;
            right: -4px;
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: var(--gold-light);
            box-shadow: 0 0 12px var(--gold-glow), 0 0 24px rgba(176, 132, 26, 0.3);
        }

        /* Scanning line effect */
        .progress-track::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 60px;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(226, 179, 74, 0.4), transparent);
            animation: scanLine 2s ease-in-out infinite;
        }

        @@keyframes scanLine {
            0% { transform: translateX(-60px); }
            100% { transform: translateX(400px); }
        }

        /* Loading dots */
        .loading-dots {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 8px;
            z-index: 20;
            opacity: 0;
            animation: fadeSlideUp 0.8s ease-out 4.5s both;
        }

        .loading-dots span {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--gold);
            animation: dotBounce 1.4s ease-in-out infinite;
        }

        .loading-dots span:nth-child(2) { animation-delay: 0.2s; }
        .loading-dots span:nth-child(3) { animation-delay: 0.4s; }

        @@keyframes dotBounce {
            0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
            40% { opacity: 1; transform: scale(1.3); }
        }

        /* ═══════════════════════════════════════════
           DECORATIVE CORNER MARKS
        ═══════════════════════════════════════════ */
        .corner-mark {
            position: fixed;
            width: 40px;
            height: 40px;
            z-index: 5;
            opacity: 0;
            animation: fadeIn 1s ease-out 5s both;
        }

        .corner-mark::before, .corner-mark::after {
            content: '';
            position: absolute;
            background: rgba(176, 132, 26, 0.25);
        }

        .corner-tl { top: 30px; left: 30px; }
        .corner-tl::before { width: 40px; height: 1px; top: 0; left: 0; }
        .corner-tl::after { width: 1px; height: 40px; top: 0; left: 0; }

        .corner-tr { top: 30px; right: 30px; }
        .corner-tr::before { width: 40px; height: 1px; top: 0; right: 0; }
        .corner-tr::after { width: 1px; height: 40px; top: 0; right: 0; }

        .corner-bl { bottom: 30px; left: 30px; }
        .corner-bl::before { width: 40px; height: 1px; bottom: 0; left: 0; }
        .corner-bl::after { width: 1px; height: 40px; bottom: 0; left: 0; }

        .corner-br { bottom: 30px; right: 30px; }
        .corner-br::before { width: 40px; height: 1px; bottom: 0; right: 0; }
        .corner-br::after { width: 1px; height: 40px; bottom: 0; right: 0; }

        @@keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* ═══════════════════════════════════════════
           FLOATING GEOMETRIC SHAPES
        ═══════════════════════════════════════════ */
        .geo-shape {
            position: fixed;
            border: 1px solid rgba(176, 132, 26, 0.08);
            z-index: 2;
            animation: geoFloat 20s linear infinite;
        }

        .geo-1 {
            width: 100px; height: 100px;
            border-radius: 50%;
            top: 15%; left: 10%;
            animation-duration: 25s;
        }

        .geo-2 {
            width: 60px; height: 60px;
            top: 70%; right: 15%;
            transform: rotate(45deg);
            animation-duration: 18s;
            animation-direction: reverse;
        }

        .geo-3 {
            width: 80px; height: 80px;
            border-radius: 50%;
            bottom: 20%; left: 5%;
            animation-duration: 22s;
        }

        .geo-4 {
            width: 40px; height: 40px;
            top: 25%; right: 8%;
            transform: rotate(30deg);
            animation-duration: 30s;
        }

        @@keyframes geoFloat {
            0% { transform: translate(0, 0) rotate(0deg); opacity: 0.3; }
            25% { transform: translate(20px, -30px) rotate(90deg); opacity: 0.6; }
            50% { transform: translate(-10px, -50px) rotate(180deg); opacity: 0.3; }
            75% { transform: translate(15px, -20px) rotate(270deg); opacity: 0.6; }
            100% { transform: translate(0, 0) rotate(360deg); opacity: 0.3; }
        }

        /* ═══════════════════════════════════════════
           EXIT ANIMATION
        ═══════════════════════════════════════════ */
        .splash-exit {
            animation: exitFade 1s ease-in-out forwards;
        }

        @@keyframes exitFade {
            0% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.5; transform: scale(1.02); }
            100% { opacity: 0; transform: scale(1.05); filter: blur(10px); }
        }

        /* ═══════════════════════════════════════════
           RESPONSIVE
        ═══════════════════════════════════════════ */
        @@media (max-width: 600px) {
            .logo-inner { width: 90px; height: 90px; }
            .logo-inner img { width: 55px; height: 55px; }
            .logo-ring:nth-child(2) { inset: -25px; }
            .logo-ring:nth-child(3) { inset: -38px; }
            .geo-shape { display: none; }
        }
    </style>
</head>
<body>
    <!-- Background -->
    <div class="splash-bg">
        <div class="grid-overlay"></div>
    </div>

    <!-- Particle Canvas -->
    <canvas id="particleCanvas"></canvas>

    <!-- Geometric Decorations -->
    <div class="geo-shape geo-1"></div>
    <div class="geo-shape geo-2"></div>
    <div class="geo-shape geo-3"></div>
    <div class="geo-shape geo-4"></div>

    <!-- Corner Marks -->
    <div class="corner-mark corner-tl"></div>
    <div class="corner-mark corner-tr"></div>
    <div class="corner-mark corner-bl"></div>
    <div class="corner-mark corner-br"></div>

    <!-- Main Content -->
    <div class="splash-content" id="splashContent">
        <!-- Logo -->
        <div class="logo-wrapper">
            <div class="logo-glow"></div>
            <div class="logo-ring"></div>
            <div class="logo-ring"></div>
            <div class="logo-ring"></div>
            <div class="logo-inner">
                <img src="https://www.rawahel.com.sa/wp-content/themes/tl4s-raoaa_rawahel/images/logo.png" alt="Rawahel Logo" />
            </div>
        </div>

        <!-- Decorative Line -->
        <div class="deco-line"></div>

        <!-- Title -->
        <h1 class="splash-title">
            المنظومة الرقمية الموحدة<br>
            لإدارة وتشغيل قطاعات<br>
            شركة رواحل المشاعر القابضة
        </h1>

        <!-- Company Name -->
        <p class="company-name">RAWAHEL AL MASHAER HOLDING CO.</p>

        <!-- Subtitle -->
        <p class="splash-subtitle">Unified Digital Management System</p>

        <!-- Bottom Deco Line -->
        <div class="deco-line-bottom"></div>
    </div>

    <!-- Progress Bar -->
    <div class="progress-container" id="progressContainer">
        <div class="progress-label">
            <span id="progressStatus">جاري تهيئة النظام...</span>
            <span id="progressPercent">0%</span>
        </div>
        <div class="progress-track">
            <div class="progress-fill" id="progressFill"></div>
        </div>
    </div>

    <!-- Loading Dots -->
    <div class="loading-dots">
        <span></span>
        <span></span>
        <span></span>
    </div>

    <script>
        // ═══════════════════════════════════════════
        // PARTICLE SYSTEM
        // ═══════════════════════════════════════════
        const canvas = document.getElementById('particleCanvas');
        const ctx = canvas.getContext('2d');

        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        resizeCanvas();
        window.addEventListener('resize', resizeCanvas);

        class Particle {
            constructor() {
                this.reset();
            }

            reset() {
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * canvas.height;
                this.size = Math.random() * 2 + 0.5;
                this.speedX = (Math.random() - 0.5) * 0.4;
                this.speedY = (Math.random() - 0.5) * 0.4;
                this.opacity = Math.random() * 0.5 + 0.1;
                this.fadeDir = Math.random() > 0.5 ? 1 : -1;
                this.color = Math.random() > 0.6
                    ? `rgba(226, 179, 74, ${this.opacity})`
                    : `rgba(176, 132, 26, ${this.opacity})`;
            }

            update() {
                this.x += this.speedX;
                this.y += this.speedY;
                this.opacity += this.fadeDir * 0.003;

                if (this.opacity <= 0.05 || this.opacity >= 0.6) {
                    this.fadeDir *= -1;
                }

                if (this.x < 0 || this.x > canvas.width || this.y < 0 || this.y > canvas.height) {
                    this.reset();
                }
            }

            draw() {
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fillStyle = this.color;
                ctx.fill();

                // Subtle glow
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size * 3, 0, Math.PI * 2);
                const gradient = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, this.size * 3);
                gradient.addColorStop(0, `rgba(176, 132, 26, ${this.opacity * 0.3})`);
                gradient.addColorStop(1, 'transparent');
                ctx.fillStyle = gradient;
                ctx.fill();
            }
        }

        const particles = [];
        const PARTICLE_COUNT = 80;
        for (let i = 0; i < PARTICLE_COUNT; i++) {
            particles.push(new Particle());
        }

        // Draw connections between nearby particles
        function drawConnections() {
            for (let i = 0; i < particles.length; i++) {
                for (let j = i + 1; j < particles.length; j++) {
                    const dx = particles[i].x - particles[j].x;
                    const dy = particles[i].y - particles[j].y;
                    const dist = Math.sqrt(dx * dx + dy * dy);

                    if (dist < 120) {
                        const opacity = (1 - dist / 120) * 0.08;
                        ctx.strokeStyle = `rgba(176, 132, 26, ${opacity})`;
                        ctx.lineWidth = 0.5;
                        ctx.beginPath();
                        ctx.moveTo(particles[i].x, particles[i].y);
                        ctx.lineTo(particles[j].x, particles[j].y);
                        ctx.stroke();
                    }
                }
            }
        }

        function animateParticles() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => {
                p.update();
                p.draw();
            });
            drawConnections();
            requestAnimationFrame(animateParticles);
        }
        animateParticles();

        // ═══════════════════════════════════════════
        // PROGRESS BAR LOGIC (10 seconds)
        // ═══════════════════════════════════════════
        const TOTAL_DURATION = 10000; // 10 seconds
        const startTime = Date.now();
        const progressFill = document.getElementById('progressFill');
        const progressPercent = document.getElementById('progressPercent');
        const progressStatus = document.getElementById('progressStatus');

        const statusMessages = [
            { at: 0,  text: 'جاري تهيئة النظام...' },
            { at: 10, text: 'تحميل وحدات الإدارة...' },
            { at: 25, text: 'ربط قواعد البيانات...' },
            { at: 40, text: 'تجهيز لوحة المؤشرات...' },
            { at: 55, text: 'مزامنة بيانات القطاعات...' },
            { at: 70, text: 'تحميل واجهة المستخدم...' },
            { at: 85, text: 'التحقق من الصلاحيات...' },
            { at: 95, text: 'جاري فتح المنظومة...' },
        ];

        let currentStatusIdx = 0;

        function updateProgress() {
            const elapsed = Date.now() - startTime;
            let pct = Math.min((elapsed / TOTAL_DURATION) * 100, 100);

            // Ease the progress (ease-in-out)
            const t = pct / 100;
            const eased = t < 0.5
                ? 4 * t * t * t
                : 1 - Math.pow(-2 * t + 2, 3) / 2;
            const displayPct = Math.round(eased * 100);

            progressFill.style.width = displayPct + '%';
            progressPercent.textContent = displayPct + '%';

            // Update status message
            while (currentStatusIdx < statusMessages.length - 1 &&
                   displayPct >= statusMessages[currentStatusIdx + 1].at) {
                currentStatusIdx++;
                progressStatus.style.opacity = '0';
                setTimeout(() => {
                    progressStatus.textContent = statusMessages[currentStatusIdx].text;
                    progressStatus.style.opacity = '1';
                }, 200);
            }

            if (pct < 100) {
                requestAnimationFrame(updateProgress);
            } else {
                // Complete — exit animation then redirect
                setTimeout(() => {
                    document.body.classList.add('splash-exit');
                    setTimeout(() => {
                        window.location.href = '/';
                    }, 900);
                }, 500);
            }
        }

        // Start progress after initial animations settle
        setTimeout(updateProgress, 4000);
    </script>
</body>
</html>
