@page
@model NewFeature.Pages.TripsModel
@{
    ViewData["Title"] = "Fleet Operations - Trips Scheduling";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="glow-text"><i class="bi bi-calendar-event me-2"></i> <span data-i18n="trips-title">Trips Scheduling</span></h1>
            <p class="text-muted mb-0" data-i18n="trips-subtitle">Coordinate driver dispatches, vehicle scheduling, and arrival logs</p>
        </div>
        <div>
            <input type="file" id="bulkUploadFile" class="d-none" accept=".xlsx" onchange="handleBulkUpload(event, '/api/trips/bulk-upload')">
            <button class="btn btn-neon-outline me-2" onclick="document.getElementById('bulkUploadFile').click()">
                <i class="bi bi-file-earmark-excel"></i> <span data-i18n="trips-btn-bulk">Bulk Upload</span>
            </button>
            <button class="btn btn-neon" onclick="openAddModal()">
                <i class="bi bi-plus-circle me-1"></i> <span data-i18n="trips-btn-add">Schedule Trip</span>
            </button>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="glass-card mb-4 p-3">
        <div class="row align-items-center g-3">
            <div class="col-12">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-glass text-muted"><i class="bi bi-search"></i></span>
                    <input type="text" id="tripSearch" class="form-control form-control-glass" placeholder="Search scheduled journeys by driver, vehicle or status..." onkeyup="filterTrips()">
                </div>
            </div>
        </div>
    </div>

    <!-- Trips Grid -->
    <div class="glass-card">
        <div class="table-responsive">
            <table class="table table-glass text-white align-middle" id="tripsTable">
                <thead>
                    <tr>
                        <th data-i18n="trips-th-vehicle">Vehicle</th>
                        <th data-i18n="trips-th-route">Route</th>
                        <th data-i18n="trips-th-project">Project</th>
                        <th data-i18n="trips-th-driver">Driver</th>
                        <th data-i18n="trips-th-departure">Departure</th>
                        <th data-i18n="trips-th-arrival">Arrival</th>
                        <th data-i18n="trips-th-status">Status</th>
                        <th data-i18n="trips-th-actions" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody id="tripsList">
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted"><i class="bi bi-arrow-repeat spin me-2"></i> Loading operational journeys...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add/Edit Trip Modal -->
<div class="modal fade" id="tripModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-glass">
            <div class="modal-header modal-header-glass">
                <h5 class="modal-title glow-text" id="modalTitle" data-i18n="trips-btn-add">Schedule Trip</h5>
                <button type="button" class="close-btn-glass" data-bs-dismiss="modal" aria-label="Close">&times;</button>
            </div>
            <form id="tripForm" onsubmit="saveTrip(event)">
                <div class="modal-body p-4">
                    <input type="hidden" id="tripId">
                    
                    <div class="mb-3">
                        <label for="vehicleId" class="form-label" data-i18n="trips-lbl-vehicle">Vehicle</label>
                        <select id="vehicleId" class="form-control form-control-glass" required>
                            <option value="" data-i18n="trips-lbl-vehicle">Select Vehicle</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="routeId" class="form-label" data-i18n="trips-lbl-route">Route</label>
                        <select id="routeId" class="form-control form-control-glass" required>
                            <option value="" data-i18n="trips-lbl-route">Select Route</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="projectId" class="form-label" data-i18n="trips-lbl-project">Project</label>
                        <select id="projectId" class="form-control form-control-glass">
                            <option value="" data-i18n="trips-lbl-project">Select Project (Optional)</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="driverId" class="form-label" data-i18n="trips-lbl-driver">Driver</label>
                        <select id="driverId" class="form-control form-control-glass" required>
                            <option value="" data-i18n="trips-lbl-driver">Select Driver</option>
                        </select>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="scheduledDeparture" class="form-label" data-i18n="trips-lbl-departure">Scheduled Departure</label>
                            <input type="datetime-local" id="scheduledDeparture" class="form-control form-control-glass" required>
                        </div>
                        <div class="col-md-6">
                            <label for="scheduledArrival" class="form-label" data-i18n="trips-lbl-arrival">Scheduled Arrival</label>
                            <input type="datetime-local" id="scheduledArrival" class="form-control form-control-glass" required>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="actualDeparture" class="form-label" data-i18n="trips-lbl-actual-departure">Actual Departure</label>
                            <input type="datetime-local" id="actualDeparture" class="form-control form-control-glass">
                        </div>
                        <div class="col-md-6">
                            <label for="actualArrival" class="form-label" data-i18n="trips-lbl-actual-arrival">Actual Arrival</label>
                            <input type="datetime-local" id="actualArrival" class="form-control form-control-glass">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="status" class="form-label" data-i18n="trips-lbl-status">Trip Status</label>
                        <select id="status" class="form-control form-control-glass" required>
                            <option value="0">Scheduled</option>
                            <option value="1">In Progress</option>
                            <option value="2">Completed</option>
                            <option value="3">Cancelled</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer modal-footer-glass">
                    <button type="button" class="btn btn-neon-outline" data-bs-dismiss="modal" data-i18n="btn-cancel">Cancel</button>
                    <button type="submit" class="btn btn-neon" data-i18n="btn-save">Save Trip</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const currentLang = localStorage.getItem('lang') || 'en';
        let trips = [];
        let vehicles = [];
        let routes = [];
        let projects = [];
        let drivers = [];

        const statusMeta = {
            0: { text: "Scheduled", class: "badge-glow-info" },
            1: { text: "In Progress", class: "badge-glow-warning" },
            2: { text: "Completed", class: "badge-glow-success" },
            3: { text: "Cancelled", class: "badge-glow-danger" }
        };

        const statusMetaAr = {
            0: { text: "مجدولة", class: "badge-glow-info" },
            1: { text: "قيد التنفيذ", class: "badge-glow-warning" },
            2: { text: "مكتملة", class: "badge-glow-success" },
            3: { text: "ملغاة", class: "badge-glow-danger" }
        };

        document.addEventListener("DOMContentLoaded", async function () {
            await loadVehicles();
            await loadRoutes();
            await loadDrivers();
            await loadProjects();
            await loadTrips();
        });

        async function loadVehicles() {
            try {
                const res = await fetch('/api/vehicles');
                if (res.ok) {
                    vehicles = await res.json();
                    const el = document.getElementById("vehicleId");
                    el.innerHTML = '<option value="" data-i18n="trips-lbl-vehicle">Select Vehicle</option>';
                    vehicles.forEach(v => {
                        el.innerHTML += `<option value="${v.id}">${v.licensePlate} (${v.make} ${v.model})</option>`;
                    });
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function loadRoutes() {
            try {
                const res = await fetch('/api/routes');
                if (res.ok) {
                    routes = await res.json();
                    const el = document.getElementById("routeId");
                    el.innerHTML = '<option value="">Select Route</option>';
                    routes.forEach(r => {
                        const name = r.name;
                        el.innerHTML += `<option value="${r.id}">${name} (${r.distanceKm} KM)</option>`;
                    });
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function loadDrivers() {
            try {
                const res = await fetch('/api/users');
                if (res.ok) {
                    const allUsers = await res.json();
                    drivers = allUsers.filter(u => u.role === 'Driver');
                    const el = document.getElementById("driverId");
                    el.innerHTML = '<option value="">Select Driver</option>';
                    drivers.forEach(d => {
                        const name = d.fullName;
                        el.innerHTML += `<option value="${d.id}">${name}</option>`;
                    });
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function loadProjects() {
            try {
                const res = await fetch('/api/projects');
                if (res.ok) {
                    projects = await res.json();
                    const el = document.getElementById("projectId");
                    el.innerHTML = '<option value="" data-i18n="trips-lbl-project">Select Project (Optional)</option>';
                    projects.forEach(p => {
                        const name = p.name;
                        el.innerHTML += `<option value="${p.id}">${name}</option>`;
                    });
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function loadTrips() {
            try {
                const res = await fetch('/api/trips');
                if (res.ok) {
                    trips = await res.json();
                    renderTrips();
                }
            } catch (err) {
                console.error(err);
            }
        }

        function renderTrips() {
            const tbody = document.getElementById("tripsList");
            tbody.innerHTML = "";

            if (trips.length === 0) {
                tbody.innerHTML = `<tr><td colspan="8" class="text-center text-muted">No scheduled trips found.</td></tr>`;
                return;
            }

            trips.forEach(t => {
                const status = currentLang === 'en' ? statusMeta[t.status] : statusMetaAr[t.status];
                const badge = `<span class="${status.class}">${status.text}</span>`;
                const dep = new Date(t.scheduledDeparture).toLocaleString();
                const arr = new Date(t.scheduledArrival).toLocaleString();

                const tr = document.createElement("tr");
                tr.innerHTML = `
                    <td><strong>${t.vehiclePlate}</strong></td>
                    <td>${t.routeName}</td>
                    <td><span class="badge badge-glow-info">${t.projectName}</span></td>
                    <td>${t.driverName}</td>
                    <td>${dep}</td>
                    <td>${arr}</td>
                    <td>${badge}</td>
                    <td class="text-end">
                        <button class="btn btn-neon-outline btn-sm me-2" onclick="viewTripDetails(${t.id})"><i class="bi bi-eye"></i></button>
                        <button class="btn btn-neon-outline btn-sm me-2" onclick="editTrip(${t.id})"><i class="bi bi-pencil-square"></i></button>
                        <button class="btn btn-neon-danger btn-sm" onclick="deleteTrip(${t.id})"><i class="bi bi-trash"></i></button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function filterTrips() {
            const query = document.getElementById("tripSearch").value.toLowerCase();
            const rows = document.querySelectorAll("#tripsList tr");

            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                if (text.includes(query)) {
                    row.style.display = "";
                } else {
                    row.style.display = "none";
                }
            });
        }

        function resetModalReadOnly(formId) {
            const form = document.getElementById(formId);
            form.querySelectorAll("input, select, textarea").forEach(el => el.disabled = false);
            const saveBtn = form.querySelector("button[type='submit']");
            if (saveBtn) saveBtn.style.display = "";
        }

        function openAddModal() {
            resetModalReadOnly("tripForm");
            document.getElementById("tripForm").reset();
            document.getElementById("tripId").value = "";
            document.getElementById("modalTitle").innerText = currentLang === 'en' ? "Schedule Trip" : "جدولة رحلة";
            
            const modal = new bootstrap.Modal(document.getElementById('tripModal'));
            modal.show();
        }

        async function editTrip(id) {
            resetModalReadOnly("tripForm");
            try {
                const res = await fetch(`/api/trips/${id}`);
                if (res.ok) {
                    const t = await res.json();
                    document.getElementById("tripId").value = t.id;
                    document.getElementById("vehicleId").value = t.vehicleId;
                    document.getElementById("routeId").value = t.routeId;
                    document.getElementById("projectId").value = t.projectId || "";
                    document.getElementById("driverId").value = t.driverId;
                    
                    document.getElementById("scheduledDeparture").value = t.scheduledDeparture.substring(0, 16);
                    document.getElementById("scheduledArrival").value = t.scheduledArrival.substring(0, 16);
                    
                    document.getElementById("actualDeparture").value = t.actualDeparture ? t.actualDeparture.substring(0, 16) : "";
                    document.getElementById("actualArrival").value = t.actualArrival ? t.actualArrival.substring(0, 16) : "";
                    
                    document.getElementById("status").value = t.status;

                    document.getElementById("modalTitle").innerText = currentLang === 'en' ? "Edit Trip Scheduling" : "تعديل جدولة الرحلة";

                    const modal = new bootstrap.Modal(document.getElementById('tripModal'));
                    modal.show();
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function viewTripDetails(id) {
            await editTrip(id);
            document.getElementById("modalTitle").innerText = currentLang === 'en' ? "Trip Details" : "تفاصيل الرحلة";
            const form = document.getElementById("tripForm");
            form.querySelectorAll("input, select, textarea").forEach(el => el.disabled = true);
            const saveBtn = form.querySelector("button[type='submit']");
            if (saveBtn) saveBtn.style.display = "none";
        }

        async function saveTrip(e) {
            e.preventDefault();

            const idVal = document.getElementById("tripId").value;
            const projectIdVal = document.getElementById("projectId").value;
            const dto = {
                id: idVal ? parseInt(idVal) : 0,
                vehicleId: parseInt(document.getElementById("vehicleId").value),
                routeId: parseInt(document.getElementById("routeId").value),
                driverId: document.getElementById("driverId").value,
                projectId: projectIdVal ? parseInt(projectIdVal) : null,
                scheduledDeparture: document.getElementById("scheduledDeparture").value,
                scheduledArrival: document.getElementById("scheduledArrival").value,
                actualDeparture: document.getElementById("actualDeparture").value || null,
                actualArrival: document.getElementById("actualArrival").value || null,
                status: parseInt(document.getElementById("status").value)
            };

            const method = idVal ? 'PUT' : 'POST';
            const url = idVal ? `/api/trips/${idVal}` : '/api/trips';

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(dto)
                });

                if (res.ok) {
                    const modalEl = document.getElementById('tripModal');
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    modal.hide();
                    loadTrips();
                } else {
                    const errText = await res.text();
                    alert("Error saving scheduled trip: Status " + res.status + " (" + res.statusText + ")\nResponse: " + (errText || "Empty Response"));
                }
            } catch (err) {
                console.error(err);
                alert("Connection error: " + err.message);
            }
        }

        async function deleteTrip(id) {
            const confirmMsg = currentLang === 'en' ? "Cancel/delete this journey?" : "هل أنت متأكد من إلغاء/حذف هذه الرحلة؟";
            if (!confirm(confirmMsg)) return;

            try {
                const res = await fetch(`/api/trips/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    loadTrips();
                } else {
                    alert("Failed to delete trip.");
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function handleBulkUpload(event, url) {
            const file = event.target.files[0];
            if (!file) return;

            const formData = new FormData();
            formData.append('file', file);

            try {
                const tbody = document.getElementById("tripsList");
                tbody.innerHTML = `<tr><td colspan="7" class="text-center text-muted"><i class="bi bi-arrow-repeat spin me-2"></i> Uploading...</td></tr>`;

                const res = await fetch(url, {
                    method: 'POST',
                    body: formData
                });

                if (res.ok) {
                    const result = await res.json();
                    let msg = currentLang === 'en' ? `Successfully imported ${result.successCount} records.` : `تم استيراد ${result.successCount} سجل بنجاح.`;
                    if (result.errors && result.errors.length > 0) {
                        msg += "\nErrors:\n" + result.errors.slice(0, 5).join('\n');
                        if (result.errors.length > 5) msg += `\n...and ${result.errors.length - 5} more errors.`;
                    }
                    alert(msg);
                } else {
                    const text = await res.text();
                    alert("Bulk upload failed: " + text);
                }
            } catch (err) {
                console.error(err);
                alert("An error occurred during bulk upload.");
            } finally {
                event.target.value = "";
                loadTrips();
            }
        }
    </script>
}
