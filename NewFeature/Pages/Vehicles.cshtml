@page
@model NewFeature.Pages.VehiclesModel
@{
    ViewData["Title"] = "Fleet Management - Vehicles";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="glow-text"><i class="bi bi-truck me-2"></i> <span data-i18n="vehicles-title">Fleet Vehicles</span></h1>
            <p class="text-muted mb-0" data-i18n="vehicles-subtitle">Manage vehicle assets, capacity, and current operational states</p>
        </div>
        <button class="btn btn-neon" onclick="openAddModal()">
            <i class="bi bi-plus-circle me-1"></i> <span data-i18n="vehicles-btn-add">Add Vehicle</span>
        </button>
    </div>

    <!-- Toolbar -->
    <div class="glass-card mb-4 p-3">
        <div class="row align-items-center g-3">
            <div class="col-12">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-glass text-muted"><i class="bi bi-search"></i></span>
                    <input type="text" id="vehicleSearch" class="form-control form-control-glass" placeholder="Search vehicles by plate, make, model or status..." onkeyup="filterVehicles()">
                </div>
            </div>
        </div>
    </div>

    <!-- Vehicles List -->
    <div class="glass-card">
        <div class="table-responsive">
            <table class="table table-glass text-white align-middle" id="vehiclesTable">
                <thead>
                    <tr>
                        <th data-i18n="vehicles-th-plate">License Plate</th>
                        <th data-i18n="vehicles-th-make">Make & Model</th>
                        <th data-i18n="vehicles-th-year">Year</th>
                        <th data-i18n="vehicles-th-capacity">Capacity</th>
                        <th data-i18n="vehicles-th-status">Status</th>
                        <th data-i18n="vehicles-th-actions" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody id="vehiclesList">
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted"><i class="bi bi-arrow-repeat spin me-2"></i> Loading fleet vehicles...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add/Edit Vehicle Modal -->
<div class="modal fade" id="vehicleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-glass">
            <div class="modal-header modal-header-glass">
                <h5 class="modal-title glow-text" id="modalTitle" data-i18n="vehicles-btn-add">Add Vehicle</h5>
                <button type="button" class="close-btn-glass" data-bs-dismiss="modal" aria-label="Close">&times;</button>
            </div>
            <form id="vehicleForm" onsubmit="saveVehicle(event)">
                <div class="modal-body p-4">
                    <input type="hidden" id="vehicleId">
                    
                    <div class="mb-3">
                        <label for="licensePlate" class="form-label" data-i18n="vehicles-lbl-plate">License Plate</label>
                        <input type="text" id="licensePlate" class="form-control form-control-glass" required>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="make" class="form-label" data-i18n="vehicles-lbl-make">Make</label>
                            <input type="text" id="make" class="form-control form-control-glass" required>
                        </div>
                        <div class="col-md-6">
                            <label for="model" class="form-label" data-i18n="vehicles-lbl-model">Model</label>
                            <input type="text" id="model" class="form-control form-control-glass" required>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="year" class="form-label" data-i18n="vehicles-lbl-year">Year</label>
                            <input type="number" id="year" class="form-control form-control-glass" min="1900" max="2100" required>
                        </div>
                        <div class="col-md-6">
                            <label for="capacity" class="form-label" data-i18n="vehicles-lbl-capacity">Capacity</label>
                            <input type="number" step="0.01" id="capacity" class="form-control form-control-glass" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="status" class="form-label" data-i18n="vehicles-lbl-status">Vehicle Status</label>
                        <select id="status" class="form-control form-control-glass" required>
                            <option value="0">Available</option>
                            <option value="1">Active</option>
                            <option value="2">In Maintenance</option>
                            <option value="3">Out Of Service</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer modal-footer-glass">
                    <button type="button" class="btn btn-neon-outline" data-bs-dismiss="modal" data-i18n="btn-cancel">Cancel</button>
                    <button type="submit" class="btn btn-neon" data-i18n="btn-save">Save Vehicle</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const currentLang = localStorage.getItem('lang') || 'en';
        let vehicles = [];

        const statusMeta = {
            0: { text: "Available", class: "badge-glow-success" },
            1: { text: "Active", class: "badge-glow-info" },
            2: { text: "In Maintenance", class: "badge-glow-warning" },
            3: { text: "Out of Service", class: "badge-glow-danger" }
        };

        const statusMetaAr = {
            0: { text: "متاحة", class: "badge-glow-success" },
            1: { text: "نشطة", class: "badge-glow-info" },
            2: { text: "قيد الصيانة", class: "badge-glow-warning" },
            3: { text: "خارج الخدمة", class: "badge-glow-danger" }
        };

        document.addEventListener("DOMContentLoaded", function () {
            loadVehicles();
        });

        async function loadVehicles() {
            try {
                const res = await fetch('/api/vehicles');
                if (res.ok) {
                    vehicles = await res.json();
                    renderVehicles();
                }
            } catch (err) {
                console.error(err);
            }
        }

        function renderVehicles() {
            const tbody = document.getElementById("vehiclesList");
            tbody.innerHTML = "";

            if (vehicles.length === 0) {
                tbody.innerHTML = `<tr><td colspan="6" class="text-center text-muted">No vehicles found.</td></tr>`;
                return;
            }

            vehicles.forEach(v => {
                const status = currentLang === 'en' ? statusMeta[v.status] : statusMetaAr[v.status];
                const badge = `<span class="${status.class}">${status.text}</span>`;

                const tr = document.createElement("tr");
                tr.innerHTML = `
                    <td><strong>${v.licensePlate}</strong></td>
                    <td>${v.make} ${v.model}</td>
                    <td>${v.year}</td>
                    <td>${v.capacity}</td>
                    <td>${badge}</td>
                    <td class="text-end">
                        <button class="btn btn-neon-outline btn-sm me-2" onclick="viewVehicleDetails(${v.id})"><i class="bi bi-eye"></i></button>
                        <button class="btn btn-neon-outline btn-sm me-2" onclick="editVehicle(${v.id})"><i class="bi bi-pencil-square"></i></button>
                        <button class="btn btn-neon-danger btn-sm" onclick="deleteVehicle(${v.id})"><i class="bi bi-trash"></i></button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function filterVehicles() {
            const query = document.getElementById("vehicleSearch").value.toLowerCase();
            const rows = document.querySelectorAll("#vehiclesList tr");

            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                if (text.includes(query)) {
                    row.style.display = "";
                } else {
                    row.style.display = "none";
                }
            });
        }

        function resetModalReadOnly(formId) {
            const form = document.getElementById(formId);
            form.querySelectorAll("input, select, textarea").forEach(el => el.disabled = false);
            const saveBtn = form.querySelector("button[type='submit']");
            if (saveBtn) saveBtn.style.display = "";
        }

        function openAddModal() {
            resetModalReadOnly("vehicleForm");
            document.getElementById("vehicleForm").reset();
            document.getElementById("vehicleId").value = "";
            document.getElementById("modalTitle").innerText = currentLang === 'en' ? "Add Vehicle" : "إضافة مركبة";
            
            const modal = new bootstrap.Modal(document.getElementById('vehicleModal'));
            modal.show();
        }

        async function editVehicle(id) {
            resetModalReadOnly("vehicleForm");
            try {
                const res = await fetch(`/api/vehicles/${id}`);
                if (res.ok) {
                    const v = await res.json();
                    document.getElementById("vehicleId").value = v.id;
                    document.getElementById("licensePlate").value = v.licensePlate;
                    document.getElementById("make").value = v.make;
                    document.getElementById("model").value = v.model;
                    document.getElementById("year").value = v.year;
                    document.getElementById("capacity").value = v.capacity;
                    document.getElementById("status").value = v.status;

                    document.getElementById("modalTitle").innerText = currentLang === 'en' ? "Edit Vehicle Info" : "تعديل معلومات المركبة";

                    const modal = new bootstrap.Modal(document.getElementById('vehicleModal'));
                    modal.show();
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function viewVehicleDetails(id) {
            await editVehicle(id);
            document.getElementById("modalTitle").innerText = currentLang === 'en' ? "Vehicle Details" : "تفاصيل المركبة";
            const form = document.getElementById("vehicleForm");
            form.querySelectorAll("input, select, textarea").forEach(el => el.disabled = true);
            const saveBtn = form.querySelector("button[type='submit']");
            if (saveBtn) saveBtn.style.display = "none";
        }

        async function saveVehicle(e) {
            e.preventDefault();

            const id = document.getElementById("vehicleId").value;
            const dto = {
                id: id ? parseInt(id) : 0,
                licensePlate: document.getElementById("licensePlate").value,
                make: document.getElementById("make").value,
                model: document.getElementById("model").value,
                year: parseInt(document.getElementById("year").value),
                capacity: parseFloat(document.getElementById("capacity").value),
                status: parseInt(document.getElementById("status").value)
            };

            const method = id ? 'PUT' : 'POST';
            const url = id ? `/api/vehicles/${id}` : '/api/vehicles';

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(dto)
                });

                if (res.ok) {
                    const modalEl = document.getElementById('vehicleModal');
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    modal.hide();
                    loadVehicles();
                } else {
                    alert("Error saving vehicle data.");
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function deleteVehicle(id) {
            const confirmMsg = currentLang === 'en' ? "Delete this vehicle?" : "هل أنت متأكد من حذف هذه المركبة؟";
            if (!confirm(confirmMsg)) return;

            try {
                const res = await fetch(`/api/vehicles/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    loadVehicles();
                } else {
                    alert("Failed to delete vehicle.");
                }
            } catch (err) {
                console.error(err);
            }
        }
    </script>
}
