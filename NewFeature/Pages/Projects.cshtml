@page
@model NewFeature.Pages.ProjectsModel
@{
    ViewData["Title"] = "Project Management";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="glow-text"><i class="bi bi-kanban me-2"></i> <span data-i18n="projects-title">Project Management</span></h1>
            <p class="text-muted mb-0" data-i18n="projects-subtitle">Configure client contracts, allocate resources, and track project status</p>
        </div>
        <button class="btn btn-neon" onclick="openAddModal()">
            <i class="bi bi-folder-plus me-1"></i> <span data-i18n="projects-btn-add">Create Project</span>
        </button>
    </div>

    <!-- Toolbar -->
    <div class="glass-card mb-4 p-3">
        <div class="row align-items-center g-3">
            <div class="col-12">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-glass text-muted"><i class="bi bi-search"></i></span>
                    <input type="text" id="projectSearch" class="form-control form-control-glass" placeholder="Search projects by name, client, status..." onkeyup="filterProjects()">
                </div>
            </div>
        </div>
    </div>

    <!-- Projects Table -->
    <div class="glass-card">
        <div class="table-responsive">
            <table class="table table-glass text-white align-middle" id="projectsTable">
                <thead>
                    <tr>
                        <th data-i18n="projects-th-name">Project Name</th>
                        <th data-i18n="projects-th-client">Client</th>
                        <th data-i18n="projects-th-value">Price</th>
                        <th data-i18n="projects-th-vehicles">Vehicles</th>
                        <th data-i18n="projects-th-trips">Trips</th>
                        <th data-i18n="projects-th-start">Start Date</th>
                        <th data-i18n="projects-th-end">End Date</th>
                        <th data-i18n="projects-th-status">Status</th>
                        <th data-i18n="projects-th-actions" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody id="projectsList">
                    <tr>
                        <td colspan="10" class="text-center py-4 text-muted"><i class="bi bi-arrow-repeat spin me-2"></i> Loading projects...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add/Edit Project Glass Modal -->
<div class="modal fade" id="projectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-glass">
            <div class="modal-header modal-header-glass">
                <h5 class="modal-title glow-text" id="modalTitle" data-i18n="projects-btn-add">Create Project</h5>
                <button type="button" class="close-btn-glass" data-bs-dismiss="modal" aria-label="Close">&times;</button>
            </div>
            <form id="projectForm" onsubmit="saveProject(event)">
                <div class="modal-body p-4">
                    <input type="hidden" id="projectId">
                    
                    <div class="mb-3">
                        <label for="clientId" class="form-label" data-i18n="projects-lbl-client">Client</label>
                        <select id="clientId" class="form-control form-control-glass" required>
                            <option value="" data-i18n="projects-lbl-client">Select Client</option>
                        </select>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="nameEn" class="form-label" data-i18n="projects-lbl-name-en">Project Name (EN)</label>
                            <input type="text" id="nameEn" class="form-control form-control-glass" required>
                        </div>
                        <div class="col-md-6">
                            <label for="nameAr" class="form-label" data-i18n="projects-lbl-name-ar">Project Name (AR)</label>
                            <input type="text" id="nameAr" class="form-control form-control-glass" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="descriptionEn" class="form-label" data-i18n="projects-lbl-desc-en">Description (EN)</label>
                        <textarea id="descriptionEn" class="form-control form-control-glass" rows="2" required></textarea>
                    </div>

                    <div class="mb-3">
                        <label for="descriptionAr" class="form-label" data-i18n="projects-lbl-desc-ar">Description (AR)</label>
                        <textarea id="descriptionAr" class="form-control form-control-glass" rows="2" required></textarea>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="startDate" class="form-label" data-i18n="projects-lbl-start">Start Date</label>
                            <input type="date" id="startDate" class="form-control form-control-glass" required>
                        </div>
                        <div class="col-md-6">
                            <label for="endDate" class="form-label" data-i18n="projects-lbl-end">End Date</label>
                            <input type="date" id="endDate" class="form-control form-control-glass" required>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label for="contractValue" class="form-label" data-i18n="projects-lbl-value">Contract Price (SAR)</label>
                            <input type="number" step="0.01" id="contractValue" class="form-control form-control-glass" required>
                        </div>
                        <div class="col-md-4">
                            <label for="requiredVehiclesCount" class="form-label" data-i18n="projects-lbl-vehicles">Vehicles Required</label>
                            <input type="number" id="requiredVehiclesCount" class="form-control form-control-glass" required>
                        </div>
                        <div class="col-md-4">
                            <label for="estimatedTripsCount" class="form-label" data-i18n="projects-lbl-trips">Trips Estimated</label>
                            <input type="number" id="estimatedTripsCount" class="form-control form-control-glass" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="status" class="form-label" data-i18n="projects-lbl-status">Project Status</label>
                        <select id="status" class="form-control form-control-glass" required>
                            <option value="0">Planning</option>
                            <option value="1">Active</option>
                            <option value="2">Completed</option>
                            <option value="3">On Hold</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer modal-footer-glass">
                    <button type="button" class="btn btn-neon-outline" data-bs-dismiss="modal" data-i18n="btn-cancel">Cancel</button>
                    <button type="submit" class="btn btn-neon" data-i18n="btn-save">Save Project</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- View Project Details / Dashboard Modal -->
<div class="modal fade" id="projectDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content modal-content-glass">
            <div class="modal-header modal-header-glass">
                <h5 class="modal-title glow-text" id="detailsModalTitle"><i class="bi bi-bar-chart-line me-2"></i> <span data-i18n="projects-details-title">Project Dashboard</span></h5>
                <button type="button" class="close-btn-glass" data-bs-dismiss="modal" aria-label="Close">&times;</button>
            </div>
            <div class="modal-body p-4 text-white">
                <!-- Info Grid -->
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <p class="mb-1 text-muted small" data-i18n="projects-lbl-client">Client</p>
                        <h6 id="detClient" class="font-semibold text-slate-200"></h6>
                    </div>
                    <div class="col-md-6">
                        <p class="mb-1 text-muted small" data-i18n="projects-lbl-value">Contract Price (SAR)</p>
                        <h6 id="detPrice" class="font-semibold text-neon"></h6>
                    </div>
                    <div class="col-md-6">
                        <p class="mb-1 text-muted small" data-i18n="projects-lbl-start">Start Date</p>
                        <h6 id="detStart" class="text-slate-200"></h6>
                    </div>
                    <div class="col-md-6">
                        <p class="mb-1 text-muted small" data-i18n="projects-lbl-end">End Date</p>
                        <h6 id="detEnd" class="text-slate-200"></h6>
                    </div>
                </div>

                <hr class="border-glass mb-4">

                <!-- Progress Section -->
                <h6 class="glow-text mb-3"><i class="bi bi-activity me-1"></i> <span data-i18n="projects-lbl-progress-title">Trip Completion Progress</span></h6>
                <div class="row g-3 mb-3 text-center">
                    <div class="col-3">
                        <div class="p-2 glass-card">
                            <h4 id="detStatTarget" class="mb-0 text-slate-100"></h4>
                            <small class="text-muted" style="font-size: 10px;" data-i18n="projects-lbl-trips">Estimated Trips</small>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="p-2 glass-card">
                            <h4 id="detStatCompleted" class="mb-0 text-success"></h4>
                            <small class="text-muted" style="font-size: 10px;" data-i18n="trips-th-status-completed">Completed</small>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="p-2 glass-card">
                            <h4 id="detStatRemaining" class="mb-0 text-warning"></h4>
                            <small class="text-muted" style="font-size: 10px;" data-i18n="projects-lbl-remaining">Remaining</small>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="p-2 glass-card">
                            <h4 id="detStatCancelled" class="mb-0 text-danger"></h4>
                            <small class="text-muted" style="font-size: 10px;" data-i18n="trips-th-status-cancelled">Cancelled</small>
                        </div>
                    </div>
                </div>

                <!-- Progress Bar -->
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1 small">
                        <span class="text-muted" data-i18n="projects-lbl-progress-rate">Completion Rate</span>
                        <span id="detProgressPercent" class="text-neon font-semibold"></span>
                    </div>
                    <div class="progress progress-glass" style="height: 12px; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(176, 132, 26, 0.2);">
                        <div id="detProgressBar" class="progress-bar" role="progressbar" style="width: 0%; background: linear-gradient(135deg, #b0841a 0%, #faf9f6 100%);"></div>
                    </div>
                </div>

                <hr class="border-glass mb-4">

                <!-- Assigned Trips list -->
                <h6 class="glow-text mb-3"><i class="bi bi-calendar-event me-1"></i> <span data-i18n="projects-lbl-trips-list">Scheduled Trips List</span></h6>
                <div class="table-responsive" style="max-height: 250px;">
                    <table class="table table-glass table-sm text-white align-middle mb-0" id="detailsTripsTable">
                        <thead>
                            <tr>
                                <th data-i18n="trips-th-vehicle">Vehicle</th>
                                <th data-i18n="trips-th-route">Route</th>
                                <th data-i18n="trips-th-driver">Driver</th>
                                <th data-i18n="trips-th-departure">Departure</th>
                                <th data-i18n="trips-th-status">Status</th>
                            </tr>
                        </thead>
                        <tbody id="detailsTripsList">
                            <tr>
                                <td colspan="5" class="text-center py-3 text-muted">No trips scheduled for this project.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer modal-footer-glass">
                <button type="button" class="btn btn-neon" data-bs-dismiss="modal" data-i18n="btn-cancel">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const currentLang = localStorage.getItem('lang') || 'en';
        let projects = [];
        let clients = [];

        const statusLabels = {
            0: { text: "Planning", class: "badge-glow-info" },
            1: { text: "Active", class: "badge-glow-success" },
            2: { text: "Completed", class: "badge-glow-success" },
            3: { text: "On Hold", class: "badge-glow-warning" }
        };

        const statusLabelsAr = {
            0: { text: "تخطيط", class: "badge-glow-info" },
            1: { text: "نشط", class: "badge-glow-success" },
            2: { text: "مكتمل", class: "badge-glow-success" },
            3: { text: "قيد الانتظار", class: "badge-glow-warning" }
        };

        document.addEventListener("DOMContentLoaded", async function () {
            await loadClients();
            await loadProjects();
        });

        async function loadClients() {
            try {
                const res = await fetch('/api/clients');
                if (res.ok) {
                    clients = await res.json();
                    const dropdown = document.getElementById("clientId");
                    dropdown.innerHTML = '<option value="">Select Client</option>';
                    clients.forEach(c => {
                        const name = c.name;
                        dropdown.innerHTML += `<option value="${c.id}">${name}</option>`;
                    });
                }
            } catch (err) {
                console.error("Error loading clients:", err);
            }
        }

        async function loadProjects() {
            try {
                const res = await fetch('/api/projects');
                if (res.ok) {
                    projects = await res.json();
                    renderProjects();
                }
            } catch (err) {
                console.error("Error loading projects:", err);
            }
        }

        function renderProjects() {
            const tbody = document.getElementById("projectsList");
            tbody.innerHTML = "";

            if (projects.length === 0) {
                tbody.innerHTML = `<tr><td colspan="10" class="text-center text-muted">No projects found.</td></tr>`;
                return;
            }

            projects.forEach(p => {
                const name = p.name;
                const client = p.clientName;
                const statusMeta = currentLang === 'en' ? statusLabels[p.status] : statusLabelsAr[p.status];
                const badge = `<span class="${statusMeta.class}">${statusMeta.text}</span>`;

                const start = new Date(p.startDate).toLocaleDateString();
                const end = new Date(p.endDate).toLocaleDateString();

                const tr = document.createElement("tr");
                tr.innerHTML = `
                    <td><strong>${name}</strong></td>
                    <td>${client}</td>
                    <td><span class="text-neon font-semibold">${p.contractValue.toLocaleString()} SAR</span></td>
                    <td><span class="badge badge-glow-info">${p.requiredVehiclesCount}</span></td>
                    <td><span class="badge badge-glow-warning">${p.estimatedTripsCount}</span></td>
                    <td>${start}</td>
                    <td>${end}</td>
                    <td>${badge}</td>
                    <td class="text-end">
                        <button class="btn btn-neon-outline btn-sm me-2" onclick="viewProjectDetails(${p.id})"><i class="bi bi-eye"></i></button>
                        <button class="btn btn-neon-outline btn-sm me-2" onclick="editProject(${p.id})"><i class="bi bi-pencil-square"></i></button>
                        <button class="btn btn-neon-danger btn-sm" onclick="deleteProject(${p.id})"><i class="bi bi-trash"></i></button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function filterProjects() {
            const query = document.getElementById("projectSearch").value.toLowerCase();
            const rows = document.querySelectorAll("#projectsList tr");

            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                if (text.includes(query)) {
                    row.style.display = "";
                } else {
                    row.style.display = "none";
                }
            });
        }

        function openAddModal() {
            document.getElementById("projectForm").reset();
            document.getElementById("projectId").value = "";
            document.getElementById("modalTitle").innerText = currentLang === 'en' ? "Create Project" : "إنشاء مشروع";
            
            const modal = new bootstrap.Modal(document.getElementById('projectModal'));
            modal.show();
        }

        const tripStatusLabels = {
            0: { text: "Scheduled", class: "badge-glow-info" },
            1: { text: "In Progress", class: "badge-glow-warning" },
            2: { text: "Completed", class: "badge-glow-success" },
            3: { text: "Cancelled", class: "badge-glow-danger" }
        };

        const tripStatusLabelsAr = {
            0: { text: "مجدولة", class: "badge-glow-info" },
            1: { text: "قيد التنفيذ", class: "badge-glow-warning" },
            2: { text: "مكتملة", class: "badge-glow-success" },
            3: { text: "ملغاة", class: "badge-glow-danger" }
        };

        async function viewProjectDetails(id) {
            try {
                const res = await fetch(`/api/projects/${id}/details`);
                if (res.ok) {
                    const data = await res.json();
                    const p = data.project;
                    
                    document.getElementById("detClient").innerText = p.clientName;
                    document.getElementById("detPrice").innerText = p.contractValue.toLocaleString() + " SAR";
                    document.getElementById("detStart").innerText = new Date(p.startDate).toLocaleDateString();
                    document.getElementById("detEnd").innerText = new Date(p.endDate).toLocaleDateString();
                    
                    document.getElementById("detStatTarget").innerText = p.estimatedTripsCount;
                    document.getElementById("detStatCompleted").innerText = data.completedTrips;
                    document.getElementById("detStatRemaining").innerText = data.activeTrips;
                    document.getElementById("detStatCancelled").innerText = data.cancelledTrips;
                    
                    document.getElementById("detProgressPercent").innerText = data.completionPercentage + "%";
                    document.getElementById("detProgressBar").style.width = data.completionPercentage + "%";
                    
                    // Render trips
                    const tbody = document.getElementById("detailsTripsList");
                    tbody.innerHTML = "";
                    
                    if (data.trips.length === 0) {
                        tbody.innerHTML = `<tr><td colspan="5" class="text-center py-3 text-muted">${currentLang === 'en' ? 'No trips scheduled for this project.' : 'لا توجد رحلات مجدولة لهذا المشروع.'}</td></tr>`;
                    } else {
                        data.trips.forEach(t => {
                            const statusMeta = currentLang === 'en' ? tripStatusLabels[t.status] : tripStatusLabelsAr[t.status];
                            const badge = `<span class="${statusMeta.class}">${statusMeta.text}</span>`;
                            const dep = new Date(t.scheduledDeparture).toLocaleString();
                            
                            const tr = document.createElement("tr");
                            tr.innerHTML = `
                                <td><strong>${t.vehiclePlate}</strong></td>
                                <td>${t.routeName}</td>
                                <td>${t.driverName}</td>
                                <td>${dep}</td>
                                <td>${badge}</td>
                            `;
                            tbody.appendChild(tr);
                        });
                    }
                    
                    const modal = new bootstrap.Modal(document.getElementById('projectDetailsModal'));
                    modal.show();
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function editProject(id) {
            try {
                const res = await fetch(`/api/projects/${id}`);
                if (res.ok) {
                    const p = await res.json();
                    document.getElementById("projectId").value = p.id;
                    document.getElementById("clientId").value = p.clientId;
                    document.getElementById("nameEn").value = p.nameEn;
                    document.getElementById("nameAr").value = p.nameAr;
                    document.getElementById("descriptionEn").value = p.descriptionEn;
                    document.getElementById("descriptionAr").value = p.descriptionAr;
                    
                    document.getElementById("startDate").value = p.startDate.split('T')[0];
                    document.getElementById("endDate").value = p.endDate.split('T')[0];
                    document.getElementById("status").value = p.status;
                    document.getElementById("contractValue").value = p.contractValue;
                    document.getElementById("requiredVehiclesCount").value = p.requiredVehiclesCount;
                    document.getElementById("estimatedTripsCount").value = p.estimatedTripsCount;

                    document.getElementById("modalTitle").innerText = currentLang === 'en' ? "Edit Project Details" : "تعديل تفاصيل المشروع";

                    const modal = new bootstrap.Modal(document.getElementById('projectModal'));
                    modal.show();
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function saveProject(e) {
            e.preventDefault();

            const id = document.getElementById("projectId").value;
            const dto = {
                id: id ? parseInt(id) : 0,
                clientId: parseInt(document.getElementById("clientId").value),
                nameEn: document.getElementById("nameEn").value,
                nameAr: document.getElementById("nameAr").value,
                descriptionEn: document.getElementById("descriptionEn").value,
                descriptionAr: document.getElementById("descriptionAr").value,
                startDate: document.getElementById("startDate").value,
                endDate: document.getElementById("endDate").value,
                status: parseInt(document.getElementById("status").value),
                contractValue: parseFloat(document.getElementById("contractValue").value),
                requiredVehiclesCount: parseInt(document.getElementById("requiredVehiclesCount").value),
                estimatedTripsCount: parseInt(document.getElementById("estimatedTripsCount").value)
            };

            const method = id ? 'PUT' : 'POST';
            const url = id ? `/api/projects/${id}` : '/api/projects';

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(dto)
                });

                if (res.ok) {
                    const modalEl = document.getElementById('projectModal');
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    modal.hide();
                    loadProjects();
                } else {
                    alert("Error saving project data.");
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function deleteProject(id) {
            const confirmMsg = currentLang === 'en' ? "Delete this project?" : "هل أنت متأكد من حذف هذا المشروع؟";
            if (!confirm(confirmMsg)) return;

            try {
                const res = await fetch(`/api/projects/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    loadProjects();
                } else {
                    alert("Failed to delete project.");
                }
            } catch (err) {
                console.error(err);
            }
        }
    </script>
}
