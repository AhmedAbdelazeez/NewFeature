@page
@model NewFeature.Pages.ProjectsModel
@{
    ViewData["Title"] = "Project Management";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="glow-text"><i class="bi bi-kanban me-2"></i> <span data-i18n="projects-title">Project Management</span></h1>
            <p class="text-muted mb-0" data-i18n="projects-subtitle">Configure client contracts, allocate resources, and track project status</p>
        </div>
        <button class="btn btn-neon" onclick="openAddModal()">
            <i class="bi bi-folder-plus me-1"></i> <span data-i18n="projects-btn-add">Create Project</span>
        </button>
    </div>

    <!-- Toolbar -->
    <div class="glass-card mb-4 p-3">
        <div class="row align-items-center g-3">
            <div class="col-12">
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-glass text-muted"><i class="bi bi-search"></i></span>
                    <input type="text" id="projectSearch" class="form-control form-control-glass" placeholder="Search projects by name, client, status..." onkeyup="filterProjects()">
                </div>
            </div>
        </div>
    </div>

    <!-- Projects Table -->
    <div class="glass-card">
        <div class="table-responsive">
            <table class="table table-glass text-white align-middle" id="projectsTable">
                <thead>
                    <tr>
                        <th data-i18n="projects-th-name">Project Name</th>
                        <th data-i18n="projects-th-client">Client</th>
                        <th data-i18n="projects-th-value">Price</th>
                        <th data-i18n="projects-th-vehicles">Vehicles</th>
                        <th data-i18n="projects-th-trips">Trips</th>
                        <th data-i18n="projects-th-start">Start Date</th>
                        <th data-i18n="projects-th-end">End Date</th>
                        <th data-i18n="projects-th-status">Status</th>
                        <th data-i18n="projects-th-actions" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody id="projectsList">
                    <tr>
                        <td colspan="10" class="text-center py-4 text-muted"><i class="bi bi-arrow-repeat spin me-2"></i> Loading projects...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- ================= Projects Dashboard & KPIs ================= -->
    <hr class="border-glass my-5">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="glow-text"><i class="bi bi-speedometer2 me-2"></i> <span data-i18n="projects-kpi-dashboard-title">Projects Performance Dashboard</span></h2>
            <p class="text-muted mb-0" data-i18n="projects-kpi-dashboard-subtitle">Real-time performance metrics and charts for active contracts</p>
        </div>
        <button class="btn btn-neon-outline btn-sm" onclick="loadProjectKpis()">
            <i class="bi bi-arrow-clockwise me-1"></i> <span data-i18n="btn-refresh">Refresh Dashboard</span>
        </button>
    </div>

    <!-- KPI Grid -->
    <div class="row g-4 mb-5" id="kpiGrid">
        <!-- 1. Project Completion Rate -->
        <div class="col-md-6 col-lg-3 col-xl-2.4">
            <div class="glass-card h-100 p-3 position-relative overflow-hidden" style="min-width: 200px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <small class="text-muted font-bold d-block mb-1" data-i18n="kpi-project-completion" style="font-size: 0.75rem; white-space: nowrap;">Project Completion Rate</small>
                        <h3 class="mb-0 text-white font-extrabold" id="kpiProjectCompletionActual" style="font-size: 1.5rem;">-%</h3>
                    </div>
                    <div class="fs-3 text-neon"><i class="bi bi-check2-circle"></i></div>
                </div>
                <div class="mt-3 pt-2 border-top border-glass d-flex justify-content-between align-items-center text-muted" style="font-size: 0.7rem;">
                    <span data-i18n="lbl-target">Target:</span>
                    <span class="font-bold text-white" id="kpiProjectCompletionTarget">100%</span>
                </div>
            </div>
        </div>

        <!-- 2. Project Delay Rate -->
        <div class="col-md-6 col-lg-3 col-xl-2.4">
            <div class="glass-card h-100 p-3 position-relative overflow-hidden" style="min-width: 200px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <small class="text-muted font-bold d-block mb-1" data-i18n="kpi-project-delay" style="font-size: 0.75rem; white-space: nowrap;">Project Delay Rate</small>
                        <h3 class="mb-0 text-danger font-extrabold" id="kpiProjectDelayActual" style="font-size: 1.5rem;">-%</h3>
                    </div>
                    <div class="fs-3 text-danger"><i class="bi bi-exclamation-triangle"></i></div>
                </div>
                <div class="mt-3 pt-2 border-top border-glass d-flex justify-content-between align-items-center text-muted" style="font-size: 0.7rem;">
                    <span data-i18n="lbl-target">Target:</span>
                    <span class="font-bold text-white" id="kpiProjectDelayTarget">0%</span>
                </div>
            </div>
        </div>

        <!-- 3. Task Completion Rate -->
        <div class="col-md-6 col-lg-3 col-xl-2.4">
            <div class="glass-card h-100 p-3 position-relative overflow-hidden" style="min-width: 200px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <small class="text-muted font-bold d-block mb-1" data-i18n="kpi-task-completion" style="font-size: 0.75rem; white-space: nowrap;">Task Completion Rate</small>
                        <h3 class="mb-0 text-white font-extrabold" id="kpiTaskCompletionActual" style="font-size: 1.5rem;">-%</h3>
                    </div>
                    <div class="fs-3 text-neon"><i class="bi bi-list-task"></i></div>
                </div>
                <div class="mt-3 pt-2 border-top border-glass d-flex justify-content-between align-items-center text-muted" style="font-size: 0.7rem;">
                    <span data-i18n="lbl-target">Target:</span>
                    <span class="font-bold text-white" id="kpiTaskCompletionTarget">100%</span>
                </div>
            </div>
        </div>

        <!-- 4. Overdue Task Rate -->
        <div class="col-md-6 col-lg-3 col-xl-2.4">
            <div class="glass-card h-100 p-3 position-relative overflow-hidden" style="min-width: 200px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <small class="text-muted font-bold d-block mb-1" data-i18n="kpi-task-overdue" style="font-size: 0.75rem; white-space: nowrap;">Overdue Task Rate</small>
                        <h3 class="mb-0 text-danger font-extrabold" id="kpiTaskOverdueActual" style="font-size: 1.5rem;">-%</h3>
                    </div>
                    <div class="fs-3 text-danger"><i class="bi bi-calendar-x"></i></div>
                </div>
                <div class="mt-3 pt-2 border-top border-glass d-flex justify-content-between align-items-center text-muted" style="font-size: 0.7rem;">
                    <span data-i18n="lbl-target">Target:</span>
                    <span class="font-bold text-white" id="kpiTaskOverdueTarget">0%</span>
                </div>
            </div>
        </div>

        <!-- 5. Milestone Completion Rate -->
        <div class="col-md-6 col-lg-3 col-xl-2.4">
            <div class="glass-card h-100 p-3 position-relative overflow-hidden" style="min-width: 200px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <small class="text-muted font-bold d-block mb-1" data-i18n="kpi-milestone-completion" style="font-size: 0.75rem; white-space: nowrap;">Milestone Completion Rate</small>
                        <h3 class="mb-0 text-white font-extrabold" id="kpiMilestoneCompletionActual" style="font-size: 1.5rem;">-%</h3>
                    </div>
                    <div class="fs-3 text-neon"><i class="bi bi-flag"></i></div>
                </div>
                <div class="mt-3 pt-2 border-top border-glass d-flex justify-content-between align-items-center text-muted" style="font-size: 0.7rem;">
                    <span data-i18n="lbl-target">Target:</span>
                    <span class="font-bold text-white" id="kpiMilestoneCompletionTarget">100%</span>
                </div>
            </div>
        </div>

        <!-- 6. Avg Project Completion % -->
        <div class="col-md-6 col-lg-3 col-xl-2.4">
            <div class="glass-card h-100 p-3 position-relative overflow-hidden" style="min-width: 200px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <small class="text-muted font-bold d-block mb-1" data-i18n="kpi-avg-progress" style="font-size: 0.75rem; white-space: nowrap;">Avg Project Progress</small>
                        <h3 class="mb-0 text-white font-extrabold" id="kpiAvgProgressActual" style="font-size: 1.5rem;">-%</h3>
                    </div>
                    <div class="fs-3 text-neon"><i class="bi bi-graph-up-arrow"></i></div>
                </div>
                <div class="mt-3 pt-2 border-top border-glass d-flex justify-content-between align-items-center text-muted" style="font-size: 0.7rem;">
                    <span data-i18n="lbl-target">Target:</span>
                    <span class="font-bold text-white" id="kpiAvgProgressTarget">100%</span>
                </div>
            </div>
        </div>

        <!-- 7. Trip Fulfillment Rate -->
        <div class="col-md-6 col-lg-3 col-xl-2.4">
            <div class="glass-card h-100 p-3 position-relative overflow-hidden" style="min-width: 200px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <small class="text-muted font-bold d-block mb-1" data-i18n="kpi-trip-fulfillment" style="font-size: 0.75rem; white-space: nowrap;">Trip Fulfillment Rate</small>
                        <h3 class="mb-0 text-white font-extrabold" id="kpiTripFulfillmentActual" style="font-size: 1.5rem;">-%</h3>
                    </div>
                    <div class="fs-3 text-neon"><i class="bi bi-truck-flatbed"></i></div>
                </div>
                <div class="mt-3 pt-2 border-top border-glass d-flex justify-content-between align-items-center text-muted" style="font-size: 0.7rem;">
                    <span data-i18n="lbl-target">Target:</span>
                    <span class="font-bold text-white" id="kpiTripFulfillmentTarget">100%</span>
                </div>
            </div>
        </div>

        <!-- 8. On-Time Trip Delivery Rate -->
        <div class="col-md-6 col-lg-3 col-xl-2.4">
            <div class="glass-card h-100 p-3 position-relative overflow-hidden" style="min-width: 200px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <small class="text-muted font-bold d-block mb-1" data-i18n="kpi-ontime-delivery" style="font-size: 0.75rem; white-space: nowrap;">On-Time Trip Delivery</small>
                        <h3 class="mb-0 text-white font-extrabold" id="kpiOnTimeDeliveryActual" style="font-size: 1.5rem;">-%</h3>
                    </div>
                    <div class="fs-3 text-neon"><i class="bi bi-clock-history"></i></div>
                </div>
                <div class="mt-3 pt-2 border-top border-glass d-flex justify-content-between align-items-center text-muted" style="font-size: 0.7rem;">
                    <span data-i18n="lbl-target">Target:</span>
                    <span class="font-bold text-white" id="kpiOnTimeDeliveryTarget">95%</span>
                </div>
            </div>
        </div>

        <!-- 9. Fleet Utilization Rate -->
        <div class="col-md-6 col-lg-3 col-xl-2.4">
            <div class="glass-card h-100 p-3 position-relative overflow-hidden" style="min-width: 200px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <small class="text-muted font-bold d-block mb-1" data-i18n="kpi-fleet-utilization" style="font-size: 0.75rem; white-space: nowrap;">Fleet Utilization Rate</small>
                        <h3 class="mb-0 text-white font-extrabold" id="kpiFleetUtilizationActual" style="font-size: 1.5rem;">-%</h3>
                    </div>
                    <div class="fs-3 text-neon"><i class="bi bi-funnel"></i></div>
                </div>
                <div class="mt-3 pt-2 border-top border-glass d-flex justify-content-between align-items-center text-muted" style="font-size: 0.7rem;">
                    <span data-i18n="lbl-target">Target:</span>
                    <span class="font-bold text-white" id="kpiFleetUtilizationTarget">85%</span>
                </div>
            </div>
        </div>

        <!-- 10. Resource Efficiency -->
        <div class="col-md-6 col-lg-3 col-xl-2.4">
            <div class="glass-card h-100 p-3 position-relative overflow-hidden" style="min-width: 200px;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <small class="text-muted font-bold d-block mb-1" data-i18n="kpi-resource-efficiency" style="font-size: 0.75rem; white-space: nowrap;">Resource Efficiency</small>
                        <h3 class="mb-0 text-white font-extrabold" id="kpiResourceEfficiencyActual" style="font-size: 1.5rem;">-%</h3>
                    </div>
                    <div class="fs-3 text-neon"><i class="bi bi-person-workspace"></i></div>
                </div>
                <div class="mt-3 pt-2 border-top border-glass d-flex justify-content-between align-items-center text-muted" style="font-size: 0.7rem;">
                    <span data-i18n="lbl-target">Target:</span>
                    <span class="font-bold text-white" id="kpiResourceEfficiencyTarget">100%</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Grid -->
    <div class="row g-4 mb-5">
        <div class="col-md-6 col-xl-3">
            <div class="glass-card p-3">
                <h5 class="glow-text text-center mb-3" style="font-size: 0.95rem;" data-i18n="chart-projects-status">Projects Status</h5>
                <div style="position: relative; height: 200px;">
                    <canvas id="chartProjectsByStatus"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="glass-card p-3">
                <h5 class="glow-text text-center mb-3" style="font-size: 0.95rem;" data-i18n="chart-tasks-status">Tasks Status</h5>
                <div style="position: relative; height: 200px;">
                    <canvas id="chartTasksByStatus"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-12 col-xl-6">
            <div class="glass-card p-3">
                <h5 class="glow-text text-center mb-3" style="font-size: 0.95rem;" data-i18n="chart-monthly-completion">Monthly Completed Tasks</h5>
                <div style="position: relative; height: 200px;">
                    <canvas id="chartMonthlyTasks"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-12">
            <div class="glass-card p-3">
                <h5 class="glow-text text-center mb-3" style="font-size: 0.95rem;" data-i18n="chart-trip-fulfillment">Trip Fulfillment Rate per Project (%)</h5>
                <div style="position: relative; height: 220px;">
                    <canvas id="chartTripFulfillment"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- Add/Edit Project Glass Modal -->
<div class="modal fade" id="projectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modal-content-glass">
            <div class="modal-header modal-header-glass">
                <h5 class="modal-title glow-text" id="modalTitle" data-i18n="projects-btn-add">Create Project</h5>
                <button type="button" class="close-btn-glass" data-bs-dismiss="modal" aria-label="Close">&times;</button>
            </div>
            <form id="projectForm" onsubmit="saveProject(event)">
                <div class="modal-body p-4">
                    <input type="hidden" id="projectId">
                    
                    <div class="mb-3">
                        <label for="clientId" class="form-label" data-i18n="projects-lbl-client">Client</label>
                        <select id="clientId" class="form-control form-control-glass" required>
                            <option value="" data-i18n="projects-lbl-client">Select Client</option>
                        </select>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="nameEn" class="form-label" data-i18n="projects-lbl-name-en">Project Name (EN)</label>
                            <input type="text" id="nameEn" class="form-control form-control-glass" required>
                        </div>
                        <div class="col-md-6">
                            <label for="nameAr" class="form-label" data-i18n="projects-lbl-name-ar">Project Name (AR)</label>
                            <input type="text" id="nameAr" class="form-control form-control-glass" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="descriptionEn" class="form-label" data-i18n="projects-lbl-desc-en">Description (EN)</label>
                        <textarea id="descriptionEn" class="form-control form-control-glass" rows="2" required></textarea>
                    </div>

                    <div class="mb-3">
                        <label for="descriptionAr" class="form-label" data-i18n="projects-lbl-desc-ar">Description (AR)</label>
                        <textarea id="descriptionAr" class="form-control form-control-glass" rows="2" required></textarea>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="startDate" class="form-label" data-i18n="projects-lbl-start">Start Date</label>
                            <input type="date" id="startDate" class="form-control form-control-glass" required>
                        </div>
                        <div class="col-md-6">
                            <label for="endDate" class="form-label" data-i18n="projects-lbl-end">End Date</label>
                            <input type="date" id="endDate" class="form-control form-control-glass" required>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label for="contractValue" class="form-label" data-i18n="projects-lbl-value">Contract Price (SAR)</label>
                            <input type="number" step="0.01" id="contractValue" class="form-control form-control-glass" required>
                        </div>
                        <div class="col-md-4">
                            <label for="requiredVehiclesCount" class="form-label" data-i18n="projects-lbl-vehicles">Vehicles Required</label>
                            <input type="number" id="requiredVehiclesCount" class="form-control form-control-glass" required>
                        </div>
                        <div class="col-md-4">
                            <label for="estimatedTripsCount" class="form-label" data-i18n="projects-lbl-trips">Trips Estimated</label>
                            <input type="number" id="estimatedTripsCount" class="form-control form-control-glass" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="status" class="form-label" data-i18n="projects-lbl-status">Project Status</label>
                        <select id="status" class="form-control form-control-glass" required>
                            <option value="0">Planning</option>
                            <option value="1">Active</option>
                            <option value="2">Completed</option>
                            <option value="3">On Hold</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer modal-footer-glass">
                    <button type="button" class="btn btn-neon-outline" data-bs-dismiss="modal" data-i18n="btn-cancel">Cancel</button>
                    <button type="submit" class="btn btn-neon" data-i18n="btn-save">Save Project</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- View Project Details / Dashboard Modal -->
<div class="modal fade" id="projectDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content modal-content-glass">
            <div class="modal-header modal-header-glass">
                <h5 class="modal-title glow-text" id="detailsModalTitle"><i class="bi bi-bar-chart-line me-2"></i> <span data-i18n="projects-details-title">Project Dashboard</span></h5>
                <button type="button" class="close-btn-glass" data-bs-dismiss="modal" aria-label="Close">&times;</button>
            </div>
            <div class="modal-body p-4 text-white">
                <!-- Info Grid -->
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <p class="mb-1 text-muted small" data-i18n="projects-lbl-client">Client</p>
                        <h6 id="detClient" class="font-semibold text-slate-200"></h6>
                    </div>
                    <div class="col-md-6">
                        <p class="mb-1 text-muted small" data-i18n="projects-lbl-value">Contract Price (SAR)</p>
                        <h6 id="detPrice" class="font-semibold text-neon"></h6>
                    </div>
                    <div class="col-md-6">
                        <p class="mb-1 text-muted small" data-i18n="projects-lbl-start">Start Date</p>
                        <h6 id="detStart" class="text-slate-200"></h6>
                    </div>
                    <div class="col-md-6">
                        <p class="mb-1 text-muted small" data-i18n="projects-lbl-end">End Date</p>
                        <h6 id="detEnd" class="text-slate-200"></h6>
                    </div>
                </div>

                <hr class="border-glass mb-4">

                <!-- Progress Section -->
                <h6 class="glow-text mb-3"><i class="bi bi-activity me-1"></i> <span data-i18n="projects-lbl-progress-title">Trip Completion Progress</span></h6>
                <div class="row g-3 mb-3 text-center">
                    <div class="col-3">
                        <div class="p-2 glass-card">
                            <h4 id="detStatTarget" class="mb-0 text-slate-100"></h4>
                            <small class="text-muted" style="font-size: 10px;" data-i18n="projects-lbl-trips">Estimated Trips</small>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="p-2 glass-card">
                            <h4 id="detStatCompleted" class="mb-0 text-success"></h4>
                            <small class="text-muted" style="font-size: 10px;" data-i18n="trips-th-status-completed">Completed</small>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="p-2 glass-card">
                            <h4 id="detStatRemaining" class="mb-0 text-warning"></h4>
                            <small class="text-muted" style="font-size: 10px;" data-i18n="projects-lbl-remaining">Remaining</small>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="p-2 glass-card">
                            <h4 id="detStatCancelled" class="mb-0 text-danger"></h4>
                            <small class="text-muted" style="font-size: 10px;" data-i18n="trips-th-status-cancelled">Cancelled</small>
                        </div>
                    </div>
                </div>

                <!-- Progress Bar -->
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1 small">
                        <span class="text-muted" data-i18n="projects-lbl-progress-rate">Completion Rate</span>
                        <span id="detProgressPercent" class="text-neon font-semibold"></span>
                    </div>
                    <div class="progress progress-glass" style="height: 12px; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(176, 132, 26, 0.2);">
                        <div id="detProgressBar" class="progress-bar" role="progressbar" style="width: 0%; background: linear-gradient(135deg, #b0841a 0%, #faf9f6 100%);"></div>
                    </div>
                </div>

                <hr class="border-glass mb-4">

                <!-- Assigned Trips list -->
                <h6 class="glow-text mb-3"><i class="bi bi-calendar-event me-1"></i> <span data-i18n="projects-lbl-trips-list">Scheduled Trips List</span></h6>
                <div class="table-responsive" style="max-height: 250px;">
                    <table class="table table-glass table-sm text-white align-middle mb-0" id="detailsTripsTable">
                        <thead>
                            <tr>
                                <th data-i18n="trips-th-vehicle">Vehicle</th>
                                <th data-i18n="trips-th-route">Route</th>
                                <th data-i18n="trips-th-driver">Driver</th>
                                <th data-i18n="trips-th-departure">Departure</th>
                                <th data-i18n="trips-th-status">Status</th>
                            </tr>
                        </thead>
                        <tbody id="detailsTripsList">
                            <tr>
                                <td colspan="5" class="text-center py-3 text-muted">No trips scheduled for this project.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer modal-footer-glass">
                <button type="button" class="btn btn-neon" data-bs-dismiss="modal" data-i18n="btn-cancel">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Manage Project Tasks Modal -->
<div class="modal fade" id="projectTasksModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content modal-content-glass">
            <div class="modal-header modal-header-glass">
                <h5 class="modal-title glow-text" id="tasksModalTitle"><i class="bi bi-gear-wide-connected me-2"></i> <span>إدارة تفاصيل المشروع</span></h5>
                <button type="button" class="close-btn-glass" data-bs-dismiss="modal" aria-label="Close">&times;</button>
            </div>
            <div class="modal-body p-4 text-slate-800">
                <!-- Bootstrap Tabs Navigation -->
                <ul class="nav nav-tabs mb-4 border-bottom border-glass" id="projectModalTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active fw-bold px-3 py-2 border-0 bg-transparent border-bottom" id="tasks-tab" data-bs-toggle="tab" data-bs-target="#tasks-tab-content" type="button" role="tab" aria-selected="true" style="border-width: 3px !important; border-color: transparent; transition: all 0.25s;"><i class="bi bi-list-check me-2"></i>المهام (Tasks)</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold px-3 py-2 border-0 bg-transparent border-bottom" id="milestones-tab" data-bs-toggle="tab" data-bs-target="#milestones-tab-content" type="button" role="tab" aria-selected="false" style="border-width: 3px !important; border-color: transparent; transition: all 0.25s;"><i class="bi bi-flag me-2"></i>المراحل الرئيسية (Milestones)</button>
                    </li>
                </ul>

                <style>
                    #projectModalTabs .nav-link {
                        color: #64748b !important;
                    }
                    #projectModalTabs .nav-link.active {
                        color: #b0841a !important;
                        border-bottom-color: #b0841a !important;
                    }
                    #projectModalTabs .nav-link:hover {
                        color: #b0841a !important;
                    }
                </style>

                <div class="tab-content" id="projectModalTabContent">
                    <!-- Tab 1: Tasks Content -->
                    <div class="tab-pane fade show active" id="tasks-tab-content" role="tabpanel" aria-labelledby="tasks-tab">
                        <!-- Task Forms (Toggled via button) -->
                        <div id="addTaskFormContainer" class="card bg-light border border-slate-200 p-4 rounded-2.5xl mb-4 d-none">
                            <h6 class="glow-text mb-3" style="font-weight: 800;"><i class="bi bi-plus-circle me-1"></i> <span id="lblAddTaskTitle">Add New Task</span></h6>
                            <form id="taskForm" onsubmit="saveTask(event)">
                                <input type="hidden" id="taskProjectId">
                                <input type="hidden" id="taskIdField">
                                
                                <div class="row g-3 mb-3">
                                    <div class="col-md-6">
                                        <label for="taskTitleAr" id="lblTaskTitleAr" class="form-label text-slate-700 font-bold mb-1">اسم المهمة (العربية) *</label>
                                        <input type="text" id="taskTitleAr" class="form-control form-control-glass bg-white" placeholder="مثال: فحص سلامة الإطارات والمكابح" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="taskTitleEn" id="lblTaskTitleEn" class="form-label text-slate-700 font-bold mb-1">Task Title (English) *</label>
                                        <input type="text" id="taskTitleEn" class="form-control form-control-glass bg-white" placeholder="e.g. Inspect Tires & Brakes" required>
                                    </div>
                                </div>
                                
                                <div class="row g-3 mb-3">
                                    <div class="col-md-6">
                                        <label for="taskDescAr" id="lblTaskDescAr" class="form-label text-slate-700 font-bold mb-1">وصف المهمة (العربية) *</label>
                                        <textarea id="taskDescAr" class="form-control form-control-glass bg-white" rows="2" placeholder="أدخل تفاصيل ومحددات إنجاز المهمة..." required></textarea>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="taskDescEn" id="lblTaskDescEn" class="form-label text-slate-700 font-bold mb-1">Task Description (English) *</label>
                                        <textarea id="taskDescEn" class="form-control form-control-glass bg-white" rows="2" placeholder="Enter task specifications and guidelines..." required></textarea>
                                    </div>
                                </div>
                                
                                <div class="row g-3 mb-4">
                                    <div class="col-md-4">
                                        <label for="taskDueDate" id="lblTaskDueDate" class="form-label text-slate-700 font-bold mb-1">تاريخ الاستحقاق *</label>
                                        <input type="date" id="taskDueDate" class="form-control form-control-glass bg-white" required>
                                    </div>
                                    <div class="col-md-4">
                                        <label for="taskHours" id="lblTaskHours" class="form-label text-slate-700 font-bold mb-1">الساعات المقدرة *</label>
                                        <input type="number" step="0.5" id="taskHours" class="form-control form-control-glass bg-white" placeholder="مثال: 15.5" required>
                                    </div>
                                    <div class="col-md-4">
                                        <label for="taskStatusSelect" id="lblTaskStatus" class="form-label text-slate-700 font-bold mb-1">حالة المهمة *</label>
                                        <select id="taskStatusSelect" class="form-control form-control-glass bg-white" required>
                                            <option value="0">لم تبدأ (To Do)</option>
                                            <option value="1">قيد التنفيذ (In Progress)</option>
                                            <option value="2">قيد المراجعة (In Review)</option>
                                            <option value="3">مكتملة (Done)</option>
                                        </select>
                                    </div>
                                </div>
                                
                                <div class="d-flex justify-content-end gap-2">
                                    <button type="button" id="btnCancelTaskForm" class="btn btn-neon-outline btn-sm" onclick="toggleAddTaskForm(false)">إلغاء</button>
                                    <button type="submit" id="btnSaveTaskForm" class="btn btn-neon btn-sm">حفظ المهمة</button>
                                </div>
                            </form>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="glow-text mb-0" style="font-weight: 800;"><i class="bi bi-tasks me-1"></i> <span id="lblTasksListHeader">Tasks List</span></h6>
                            <button class="btn btn-neon btn-sm" onclick="toggleAddTaskForm(true)">
                                <i class="bi bi-plus-circle me-1"></i> <span id="btnAddTaskTrigger">إضافة مهمة جديدة</span>
                            </button>
                        </div>

                        <!-- Tasks list table -->
                        <div class="table-responsive" style="max-height: 350px;">
                            <table class="table table-glass table-sm text-slate-800 align-middle mb-0" id="projectTasksTable">
                                <thead>
                                    <tr class="text-slate-400">
                                        <th>اسم المهمة</th>
                                        <th>الحالة</th>
                                        <th>تاريخ الاستحقاق</th>
                                        <th>ساعات العمل</th>
                                        <th class="text-end">الإجراءات</th>
                                    </tr>
                                </thead>
                                <tbody id="projectTasksList" class="text-slate-700">
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-muted">لا توجد مهام مدخلة لهذا المشروع حالياً.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Tab 2: Milestones Content -->
                    <div class="tab-pane fade" id="milestones-tab-content" role="tabpanel" aria-labelledby="milestones-tab">
                        <!-- Milestone Form (Toggled via button) -->
                        <div id="addMilestoneFormContainer" class="card bg-light border border-slate-200 p-4 rounded-2.5xl mb-4 d-none">
                            <h6 class="glow-text mb-3" style="font-weight: 800;"><i class="bi bi-plus-circle me-1"></i> <span id="lblAddMilestoneTitle">إضافة مرحلة رئيسية جديدة</span></h6>
                            <form id="milestoneForm" onsubmit="saveMilestone(event)">
                                <input type="hidden" id="milestoneProjectId">
                                <input type="hidden" id="milestoneIdField">
                                
                                <div class="row g-3 mb-3">
                                    <div class="col-md-6">
                                        <label for="milestoneTitleAr" class="form-label text-slate-700 font-bold mb-1">اسم المرحلة (العربية) *</label>
                                        <input type="text" id="milestoneTitleAr" class="form-control form-control-glass bg-white" placeholder="مثال: وصول الفوج الأول من الحجاج" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="milestoneTitleEn" class="form-label text-slate-700 font-bold mb-1">Milestone Title (English) *</label>
                                        <input type="text" id="milestoneTitleEn" class="form-control form-control-glass bg-white" placeholder="e.g. Arrival of first pilgrims batch" required>
                                    </div>
                                </div>
                                
                                <div class="row g-3 mb-4">
                                    <div class="col-md-6">
                                        <label for="milestoneDueDate" class="form-label text-slate-700 font-bold mb-1">تاريخ الاستحقاق *</label>
                                        <input type="date" id="milestoneDueDate" class="form-control form-control-glass bg-white" required>
                                    </div>
                                    <div class="col-md-6 d-flex align-items-end pb-2">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" role="switch" id="milestoneIsCompleted">
                                            <label class="form-check-label text-slate-700 font-bold ms-2" for="milestoneIsCompleted">مكتملة (Completed)</label>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="d-flex justify-content-end gap-2">
                                    <button type="button" class="btn btn-neon-outline btn-sm" onclick="toggleAddMilestoneForm(false)">إلغاء</button>
                                    <button type="submit" class="btn btn-neon btn-sm">حفظ المرحلة</button>
                                </div>
                            </form>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="glow-text mb-0" style="font-weight: 800;"><i class="bi bi-flag me-1"></i> <span>قائمة المراحل الرئيسية</span></h6>
                            <button class="btn btn-neon btn-sm" onclick="toggleAddMilestoneForm(true)">
                                <i class="bi bi-plus-circle me-1"></i> <span>إضافة مرحلة جديدة</span>
                            </button>
                        </div>

                        <!-- Milestones list table -->
                        <div class="table-responsive" style="max-height: 350px;">
                            <table class="table table-glass table-sm text-slate-800 align-middle mb-0" id="projectMilestonesTable">
                                <thead>
                                    <tr class="text-slate-400">
                                        <th>اسم المرحلة</th>
                                        <th>الحالة</th>
                                        <th>تاريخ الاستحقاق</th>
                                        <th class="text-end">الإجراءات</th>
                                    </tr>
                                </thead>
                                <tbody id="projectMilestonesList" class="text-slate-700">
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">لا توجد مراحل رئيسية مدخلة لهذا المشروع حالياً.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer modal-footer-glass">
                <button type="button" id="btnModalClose" class="btn btn-neon" data-bs-dismiss="modal">إغلاق</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <partial name="_ValidationScriptsPartial" />
    <script>
        const currentLang = localStorage.getItem('lang') || 'en';
        let projects = [];
        let clients = [];

        const statusLabels = {
            0: { text: "Planning", class: "badge-glow-info" },
            1: { text: "Active", class: "badge-glow-success" },
            2: { text: "Completed", class: "badge-glow-success" },
            3: { text: "On Hold", class: "badge-glow-warning" }
        };

        const statusLabelsAr = {
            0: { text: "تخطيط", class: "badge-glow-info" },
            1: { text: "نشط", class: "badge-glow-success" },
            2: { text: "مكتمل", class: "badge-glow-success" },
            3: { text: "قيد الانتظار", class: "badge-glow-warning" }
        };

        document.addEventListener("DOMContentLoaded", async function () {
            await loadClients();
            await loadProjects();
            await loadProjectKpis();
        });

        async function loadClients() {
            try {
                const res = await fetch('/api/clients');
                if (res.ok) {
                    clients = await res.json();
                    const dropdown = document.getElementById("clientId");
                    dropdown.innerHTML = '<option value="">Select Client</option>';
                    clients.forEach(c => {
                        const name = c.name;
                        dropdown.innerHTML += `<option value="${c.id}">${name}</option>`;
                    });
                }
            } catch (err) {
                console.error("Error loading clients:", err);
            }
        }

        async function loadProjects() {
            try {
                const res = await fetch('/api/projects');
                if (res.ok) {
                    projects = await res.json();
                    renderProjects();
                }
            } catch (err) {
                console.error("Error loading projects:", err);
            }
        }

        function renderProjects() {
            const tbody = document.getElementById("projectsList");
            tbody.innerHTML = "";

            if (projects.length === 0) {
                tbody.innerHTML = `<tr><td colspan="10" class="text-center text-muted">No projects found.</td></tr>`;
                return;
            }

            projects.forEach(p => {
                const name = p.name;
                const client = p.clientName;
                const statusMeta = currentLang === 'en' ? statusLabels[p.status] : statusLabelsAr[p.status];
                const badge = `<span class="${statusMeta.class}">${statusMeta.text}</span>`;

                const start = new Date(p.startDate).toLocaleDateString();
                const end = new Date(p.endDate).toLocaleDateString();

                const tr = document.createElement("tr");
                tr.innerHTML = `
                    <td><strong>${name}</strong></td>
                    <td>${client}</td>
                    <td><span class="text-neon font-semibold">${p.contractValue.toLocaleString()} SAR</span></td>
                    <td><span class="badge badge-glow-info">${p.requiredVehiclesCount}</span></td>
                    <td><span class="badge badge-glow-warning">${p.estimatedTripsCount}</span></td>
                    <td>${start}</td>
                    <td>${end}</td>
                    <td>${badge}</td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-1 flex-nowrap">
                            <button class="btn btn-neon-outline btn-sm" onclick="viewProjectDetails(${p.id})" title="View Details"><i class="bi bi-eye"></i></button>
                            <button class="btn btn-neon-outline btn-sm" onclick="openProjectTasksModal(${p.id})" title="Manage Tasks"><i class="bi bi-list-check"></i></button>
                            <button class="btn btn-neon-outline btn-sm" onclick="editProject(${p.id})" title="Edit"><i class="bi bi-pencil-square"></i></button>
                            <button class="btn btn-neon-danger btn-sm" onclick="deleteProject(${p.id})" title="Delete"><i class="bi bi-trash"></i></button>
                        </div>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function filterProjects() {
            const query = document.getElementById("projectSearch").value.toLowerCase();
            const rows = document.querySelectorAll("#projectsList tr");

            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                if (text.includes(query)) {
                    row.style.display = "";
                } else {
                    row.style.display = "none";
                }
            });
        }

        function openAddModal() {
            document.getElementById("projectForm").reset();
            document.getElementById("projectId").value = "";
            document.getElementById("modalTitle").innerText = currentLang === 'en' ? "Create Project" : "إنشاء مشروع";
            
            const modal = new bootstrap.Modal(document.getElementById('projectModal'));
            modal.show();
        }

        const tripStatusLabels = {
            0: { text: "Scheduled", class: "badge-glow-info" },
            1: { text: "In Progress", class: "badge-glow-warning" },
            2: { text: "Completed", class: "badge-glow-success" },
            3: { text: "Cancelled", class: "badge-glow-danger" }
        };

        const tripStatusLabelsAr = {
            0: { text: "مجدولة", class: "badge-glow-info" },
            1: { text: "قيد التنفيذ", class: "badge-glow-warning" },
            2: { text: "مكتملة", class: "badge-glow-success" },
            3: { text: "ملغاة", class: "badge-glow-danger" }
        };

        async function viewProjectDetails(id) {
            try {
                const res = await fetch(`/api/projects/${id}/details`);
                if (res.ok) {
                    const data = await res.json();
                    const p = data.project;
                    
                    document.getElementById("detClient").innerText = p.clientName;
                    document.getElementById("detPrice").innerText = p.contractValue.toLocaleString() + " SAR";
                    document.getElementById("detStart").innerText = new Date(p.startDate).toLocaleDateString();
                    document.getElementById("detEnd").innerText = new Date(p.endDate).toLocaleDateString();
                    
                    document.getElementById("detStatTarget").innerText = p.estimatedTripsCount;
                    document.getElementById("detStatCompleted").innerText = data.completedTrips;
                    document.getElementById("detStatRemaining").innerText = data.activeTrips;
                    document.getElementById("detStatCancelled").innerText = data.cancelledTrips;
                    
                    document.getElementById("detProgressPercent").innerText = data.completionPercentage + "%";
                    document.getElementById("detProgressBar").style.width = data.completionPercentage + "%";
                    
                    // Render trips
                    const tbody = document.getElementById("detailsTripsList");
                    tbody.innerHTML = "";
                    
                    if (data.trips.length === 0) {
                        tbody.innerHTML = `<tr><td colspan="5" class="text-center py-3 text-muted">${currentLang === 'en' ? 'No trips scheduled for this project.' : 'لا توجد رحلات مجدولة لهذا المشروع.'}</td></tr>`;
                    } else {
                        data.trips.forEach(t => {
                            const statusMeta = currentLang === 'en' ? tripStatusLabels[t.status] : tripStatusLabelsAr[t.status];
                            const badge = `<span class="${statusMeta.class}">${statusMeta.text}</span>`;
                            const dep = new Date(t.scheduledDeparture).toLocaleString();
                            
                            const tr = document.createElement("tr");
                            tr.innerHTML = `
                                <td><strong>${t.vehiclePlate}</strong></td>
                                <td>${t.routeName}</td>
                                <td>${t.driverName}</td>
                                <td>${dep}</td>
                                <td>${badge}</td>
                            `;
                            tbody.appendChild(tr);
                        });
                    }
                    
                    const modal = new bootstrap.Modal(document.getElementById('projectDetailsModal'));
                    modal.show();
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function editProject(id) {
            try {
                const res = await fetch(`/api/projects/${id}`);
                if (res.ok) {
                    const p = await res.json();
                    document.getElementById("projectId").value = p.id;
                    document.getElementById("clientId").value = p.clientId;
                    document.getElementById("nameEn").value = p.nameEn;
                    document.getElementById("nameAr").value = p.nameAr;
                    document.getElementById("descriptionEn").value = p.descriptionEn;
                    document.getElementById("descriptionAr").value = p.descriptionAr;
                    
                    document.getElementById("startDate").value = p.startDate.split('T')[0];
                    document.getElementById("endDate").value = p.endDate.split('T')[0];
                    document.getElementById("status").value = p.status;
                    document.getElementById("contractValue").value = p.contractValue;
                    document.getElementById("requiredVehiclesCount").value = p.requiredVehiclesCount;
                    document.getElementById("estimatedTripsCount").value = p.estimatedTripsCount;

                    document.getElementById("modalTitle").innerText = currentLang === 'en' ? "Edit Project Details" : "تعديل تفاصيل المشروع";

                    const modal = new bootstrap.Modal(document.getElementById('projectModal'));
                    modal.show();
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function saveProject(e) {
            e.preventDefault();

            const id = document.getElementById("projectId").value;
            const dto = {
                id: id ? parseInt(id) : 0,
                clientId: parseInt(document.getElementById("clientId").value),
                nameEn: document.getElementById("nameEn").value,
                nameAr: document.getElementById("nameAr").value,
                descriptionEn: document.getElementById("descriptionEn").value,
                descriptionAr: document.getElementById("descriptionAr").value,
                startDate: document.getElementById("startDate").value,
                endDate: document.getElementById("endDate").value,
                status: parseInt(document.getElementById("status").value),
                contractValue: parseFloat(document.getElementById("contractValue").value),
                requiredVehiclesCount: parseInt(document.getElementById("requiredVehiclesCount").value),
                estimatedTripsCount: parseInt(document.getElementById("estimatedTripsCount").value)
            };

            const method = id ? 'PUT' : 'POST';
            const url = id ? `/api/projects/${id}` : '/api/projects';

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(dto)
                });

                if (res.ok) {
                    const modalEl = document.getElementById('projectModal');
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    modal.hide();
                    loadProjects();
                } else {
                    alert("Error saving project data.");
                }
            } catch (err) {
                console.error(err);
            }
        }

        async function deleteProject(id) {
            const confirmMsg = currentLang === 'en' ? "Delete this project?" : "هل أنت متأكد من حذف هذا المشروع؟";
            if (!confirm(confirmMsg)) return;

            try {
                const res = await fetch(`/api/projects/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    loadProjects();
                } else {
                    alert("Failed to delete project.");
                }
            } catch (err) {
                console.error(err);
            }
        }

        // ================= Tasks Management Handlers =================
        let activeProjectIdForTasks = null;
        let projectTasks = [];

        function toggleAddTaskForm(show) {
            const form = document.getElementById("addTaskFormContainer");
            const btn = document.getElementById("btnAddTaskTrigger");
            if (show) {
                form.classList.remove("d-none");
                if (btn) btn.classList.add("d-none");
                document.getElementById("taskForm").reset();
                document.getElementById("taskIdField").value = "";
                document.getElementById("taskProjectId").value = activeProjectIdForTasks;
            } else {
                form.classList.add("d-none");
                if (btn) btn.classList.remove("d-none");
            }
        }

        async function openProjectTasksModal(projectId) {
            activeProjectIdForTasks = projectId;
            const project = projects.find(p => p.id === projectId);
            const title = project ? (currentLang === 'en' ? project.nameEn : project.nameAr) : '';
            
            document.getElementById("tasksModalTitle").querySelector("span").innerText = 
                currentLang === 'en' ? `إدارة تفاصيل المشروع: ${title}` : `إدارة تفاصيل المشروع: ${title}`;
            
            translateTaskModal();
            toggleAddTaskForm(false);
            toggleAddMilestoneForm(false);
            
            // Set active tab to Tasks by default
            const tasksTabEl = document.getElementById('tasks-tab');
            const tab = new bootstrap.Tab(tasksTabEl);
            tab.show();
            
            await Promise.all([loadProjectTasks(), loadProjectMilestones()]);
            
            const modal = new bootstrap.Modal(document.getElementById('projectTasksModal'));
            modal.show();
        }

        function translateTaskModal() {
            const isEn = currentLang === 'en';
            
            // Labels
            document.getElementById("lblAddTaskTitle").innerText = isEn ? "Add New Task" : "إضافة مهمة جديدة";
            document.getElementById("lblTaskTitleAr").innerText = isEn ? "Task Title (Arabic) *" : "اسم المهمة (العربية) *";
            document.getElementById("lblTaskTitleEn").innerText = isEn ? "Task Title (English) *" : "اسم المهمة (الإنجليزية) *";
            document.getElementById("lblTaskDescAr").innerText = isEn ? "Description (Arabic) *" : "وصف المهمة (العربية) *";
            document.getElementById("lblTaskDescEn").innerText = isEn ? "Description (English) *" : "وصف المهمة (الإنجليزية) *";
            document.getElementById("lblTaskDueDate").innerText = isEn ? "Due Date *" : "تاريخ الاستحقاق *";
            document.getElementById("lblTaskHours").innerText = isEn ? "Estimated Hours *" : "الساعات المقدرة *";
            document.getElementById("lblTaskStatus").innerText = isEn ? "Task Status *" : "حالة المهمة *";
            
            // Placeholders
            document.getElementById("taskTitleAr").placeholder = isEn ? "e.g. Inspect Tires & Brakes" : "مثال: فحص سلامة الإطارات والمكابح";
            document.getElementById("taskTitleEn").placeholder = isEn ? "e.g. Inspect Tires & Brakes" : "e.g. Inspect Tires & Brakes";
            document.getElementById("taskDescAr").placeholder = isEn ? "Enter task details..." : "أدخل تفاصيل ومحددات إنجاز المهمة...";
            document.getElementById("taskDescEn").placeholder = isEn ? "Enter task details..." : "Enter task details...";
            document.getElementById("taskHours").placeholder = isEn ? "e.g. 15.5" : "مثال: 15.5";
            
            // Buttons
            document.getElementById("btnCancelTaskForm").innerText = isEn ? "Cancel" : "إلغاء";
            document.getElementById("btnSaveTaskForm").innerText = isEn ? "Save Task" : "حفظ المهمة";
            
            const triggerTextSpan = document.getElementById("btnAddTaskTrigger").querySelector("span");
            if (triggerTextSpan) {
                triggerTextSpan.innerText = isEn ? "Add New Task" : "إضافة مهمة جديدة";
            }
            
            document.getElementById("lblTasksListHeader").innerText = isEn ? "Tasks List" : "قائمة المهام";
            document.getElementById("btnModalClose").innerText = isEn ? "Close" : "إغلاق";
            
            // Table headers
            const tableHeaders = document.getElementById("projectTasksTable").querySelectorAll("thead th");
            if (tableHeaders.length === 5) {
                tableHeaders[0].innerText = isEn ? "Task Title" : "اسم المهمة";
                tableHeaders[1].innerText = isEn ? "Status" : "الحالة";
                tableHeaders[2].innerText = isEn ? "Due Date" : "تاريخ الاستحقاق";
                tableHeaders[3].innerText = isEn ? "Hours" : "ساعات العمل";
                tableHeaders[4].innerText = isEn ? "Actions" : "الإجراءات";
            }
        }

        async function loadProjectTasks() {
            try {
                const res = await fetch('/api/tasks');
                if (res.ok) {
                    const allTasks = await res.json();
                    projectTasks = allTasks.filter(t => t.projectId === activeProjectIdForTasks);
                    renderProjectTasks();
                }
            } catch (err) {
                console.error("Error loading tasks:", err);
            }
        }

        const taskStatusMeta = {
            0: { text: "To Do", class: "badge-glow-info" },
            1: { text: "In Progress", class: "badge-glow-warning" },
            2: { text: "In Review", class: "badge-glow-info" },
            3: { text: "Done", class: "badge-glow-success" }
        };

        const taskStatusMetaAr = {
            0: { text: "لم تبدأ", class: "badge-glow-info" },
            1: { text: "قيد التنفيذ", class: "badge-glow-warning" },
            2: { text: "قيد المراجعة", class: "badge-glow-info" },
            3: { text: "مكتمل", class: "badge-glow-success" }
        };

        function renderProjectTasks() {
            const tbody = document.getElementById("projectTasksList");
            tbody.innerHTML = "";

            if (projectTasks.length === 0) {
                tbody.innerHTML = `<tr><td colspan="5" class="text-center py-3 text-muted">${currentLang === 'en' ? 'No tasks defined for this project.' : 'لا توجد مهام مدخلة لهذا المشروع.'}</td></tr>`;
                return;
            }

            projectTasks.forEach(t => {
                const title = currentLang === 'en' ? (t.titleEn || t.title) : (t.titleAr || t.title);
                const statusInfo = currentLang === 'en' ? taskStatusMeta[t.status] : taskStatusMetaAr[t.status];
                const date = new Date(t.dueDate).toLocaleDateString();

                const tr = document.createElement("tr");
                tr.innerHTML = `
                    <td><strong>${title}</strong></td>
                    <td><span class="${statusInfo.class}">${statusInfo.text}</span></td>
                    <td>${date}</td>
                    <td>${t.estimatedHours} hrs</td>
                    <td class="text-end">
                        <button class="btn btn-neon-outline btn-sm me-1" onclick="editTask(${t.id})"><i class="bi bi-pencil-square"></i></button>
                        <button class="btn btn-neon-danger btn-sm" onclick="deleteTask(${t.id})"><i class="bi bi-trash"></i></button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        async function saveTask(e) {
            e.preventDefault();
            
            const titleAr = document.getElementById("taskTitleAr").value.trim();
            const titleEn = document.getElementById("taskTitleEn").value.trim();
            const descAr = document.getElementById("taskDescAr").value.trim();
            const descEn = document.getElementById("taskDescEn").value.trim();
            const dueDate = document.getElementById("taskDueDate").value;
            const hoursVal = document.getElementById("taskHours").value.trim();
            
            if (!titleAr || !titleEn || !descAr || !descEn || !dueDate || !hoursVal) {
                alert(currentLang === 'en' ? "Please fill in all required fields." : "يرجى تعبئة جميع الحقول المطلوبة.");
                return;
            }

            const hours = parseFloat(hoursVal);
            if (isNaN(hours) || hours <= 0) {
                alert(currentLang === 'en' ? "Please enter a valid number of estimated hours." : "يرجى إدخال عدد ساعات تقديري صالح.");
                return;
            }

            const btnSave = document.getElementById("btnSaveTaskForm");
            const originalText = btnSave.innerText;
            btnSave.disabled = true;
            btnSave.innerText = currentLang === 'en' ? "Saving..." : "جاري الحفظ...";

            const idField = document.getElementById("taskIdField").value;
            const dto = {
                id: idField ? parseInt(idField) : 0,
                projectId: activeProjectIdForTasks,
                titleEn: titleEn,
                titleAr: titleAr,
                title: titleAr,
                descriptionEn: descEn,
                descriptionAr: descAr,
                description: descAr,
                dueDate: dueDate,
                estimatedHours: hours,
                status: parseInt(document.getElementById("taskStatusSelect").value)
            };

            const method = idField ? 'PUT' : 'POST';
            const url = idField ? `/api/tasks/${idField}` : '/api/tasks';

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(dto)
                });

                if (res.ok) {
                    toggleAddTaskForm(false);
                    await loadProjectTasks();
                } else {
                    const errText = await res.text();
                    alert((currentLang === 'en' ? "Error saving task: " : "حدث خطأ أثناء حفظ المهمة: ") + (errText || res.statusText));
                }
            } catch (err) {
                console.error(err);
                alert("Connection error: " + err.message);
            } finally {
                btnSave.disabled = false;
                btnSave.innerText = originalText;
            }
        }

        function editTask(id) {
            const t = projectTasks.find(task => task.id === id);
            if (!t) return;

            toggleAddTaskForm(true);
            document.getElementById("taskIdField").value = t.id;
            document.getElementById("taskTitleEn").value = t.titleEn || t.title;
            document.getElementById("taskTitleAr").value = t.titleAr || t.title;
            document.getElementById("taskDescEn").value = t.descriptionEn || t.description;
            document.getElementById("taskDescAr").value = t.descriptionAr || t.description;
            document.getElementById("taskDueDate").value = t.dueDate.split('T')[0];
            document.getElementById("taskHours").value = t.estimatedHours;
            document.getElementById("taskStatusSelect").value = t.status;
        }

        async function deleteTask(id) {
            const confirmMsg = currentLang === 'en' ? "Delete this task?" : "هل أنت متأكد من حذف هذه المهمة؟";
            if (!confirm(confirmMsg)) return;

            try {
                const res = await fetch(`/api/tasks/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    await loadProjectTasks();
                } else {
                    alert("Failed to delete task.");
                }
            } catch (err) {
                console.error(err);
            }
        }

        // ================= Milestones Management Handlers =================
        let projectMilestones = [];

        function toggleAddMilestoneForm(show) {
            const form = document.getElementById("addMilestoneFormContainer");
            const btn = document.getElementById("milestones-tab-content").querySelector(".btn-neon");
            if (show) {
                form.classList.remove("d-none");
                if (btn) btn.classList.add("d-none");
                document.getElementById("milestoneForm").reset();
                document.getElementById("milestoneIdField").value = "";
                document.getElementById("milestoneProjectId").value = activeProjectIdForTasks;
            } else {
                form.classList.add("d-none");
                if (btn) btn.classList.remove("d-none");
            }
        }

        async function loadProjectMilestones() {
            try {
                const res = await fetch('/api/milestones');
                if (res.ok) {
                    const allMilestones = await res.json();
                    projectMilestones = allMilestones.filter(m => m.projectId === activeProjectIdForTasks);
                    renderProjectMilestones();
                }
            } catch (err) {
                console.error("Error loading milestones:", err);
            }
        }

        function renderProjectMilestones() {
            const tbody = document.getElementById("projectMilestonesList");
            tbody.innerHTML = "";

            if (projectMilestones.length === 0) {
                tbody.innerHTML = `<tr><td colspan="4" class="text-center py-3 text-muted">${currentLang === 'en' ? 'No milestones defined for this project.' : 'لا توجد مراحل رئيسية مدخلة لهذا المشروع.'}</td></tr>`;
                return;
            }

            projectMilestones.forEach(m => {
                const title = currentLang === 'en' ? (m.titleEn || m.titleAr) : (m.titleAr || m.titleEn);
                const statusClass = m.isCompleted ? "badge-glow-success" : "badge-glow-info";
                const statusText = m.isCompleted 
                    ? (currentLang === 'en' ? "Completed" : "مكتملة") 
                    : (currentLang === 'en' ? "Pending" : "قيد الانتظار");
                const date = new Date(m.dueDate).toLocaleDateString();

                const tr = document.createElement("tr");
                tr.innerHTML = `
                    <td><strong>${title}</strong></td>
                    <td><span class="${statusClass}">${statusText}</span></td>
                    <td>${date}</td>
                    <td class="text-end">
                        <button class="btn btn-neon-outline btn-sm me-1" onclick="editMilestone(${m.id})"><i class="bi bi-pencil-square"></i></button>
                        <button class="btn btn-neon-danger btn-sm" onclick="deleteMilestone(${m.id})"><i class="bi bi-trash"></i></button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        async function saveMilestone(e) {
            e.preventDefault();
            
            const titleAr = document.getElementById("milestoneTitleAr").value.trim();
            const titleEn = document.getElementById("milestoneTitleEn").value.trim();
            const dueDate = document.getElementById("milestoneDueDate").value;
            const isCompleted = document.getElementById("milestoneIsCompleted").checked;
            
            if (!titleAr || !titleEn || !dueDate) {
                alert(currentLang === 'en' ? "Please fill in all required fields." : "يرجى تعبئة جميع الحقول المطلوبة.");
                return;
            }

            const btnSave = document.getElementById("milestoneForm").querySelector("button[type='submit']");
            const originalText = btnSave.innerText;
            btnSave.disabled = true;
            btnSave.innerText = currentLang === 'en' ? "Saving..." : "جاري الحفظ...";

            const idField = document.getElementById("milestoneIdField").value;
            const dto = {
                id: idField ? parseInt(idField) : 0,
                projectId: activeProjectIdForTasks,
                titleEn: titleEn,
                titleAr: titleAr,
                dueDate: dueDate,
                isCompleted: isCompleted
            };

            const method = idField ? 'PUT' : 'POST';
            const url = idField ? `/api/milestones/${idField}` : '/api/milestones';

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(dto)
                });

                if (res.ok) {
                    toggleAddMilestoneForm(false);
                    await loadProjectMilestones();
                } else {
                    const errText = await res.text();
                    alert((currentLang === 'en' ? "Error saving milestone: " : "حدث خطأ أثناء حفظ المرحلة: ") + (errText || res.statusText));
                }
            } catch (err) {
                console.error(err);
                alert("Connection error: " + err.message);
            } finally {
                btnSave.disabled = false;
                btnSave.innerText = originalText;
            }
        }

        function editMilestone(id) {
            const m = projectMilestones.find(ms => ms.id === id);
            if (!m) return;

            toggleAddMilestoneForm(true);
            document.getElementById("milestoneIdField").value = m.id;
            document.getElementById("milestoneTitleEn").value = m.titleEn;
            document.getElementById("milestoneTitleAr").value = m.titleAr;
            document.getElementById("milestoneDueDate").value = m.dueDate.split('T')[0];
            document.getElementById("milestoneIsCompleted").checked = m.isCompleted;
        }

        async function deleteMilestone(id) {
            const confirmMsg = currentLang === 'en' ? "Delete this milestone?" : "هل أنت متأكد من حذف هذه المرحلة؟";
            if (!confirm(confirmMsg)) return;

            try {
                const res = await fetch(`/api/milestones/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    await loadProjectMilestones();
                } else {
                    alert("Failed to delete milestone.");
                }
            } catch (err) {
                console.error(err);
            }
        }

        // ================= KPI Dashboard & Chart Rendering =================
        let chartProj = null;
        let chartTask = null;
        let chartMonthly = null;
        let chartFulfillment = null;

        async function loadProjectKpis() {
            try {
                const res = await fetch('/api/dashboard/project-kpis');
                if (res.ok) {
                    const data = await res.json();
                    
                    // Update KPI cards
                    document.getElementById("kpiProjectCompletionActual").innerText = data.projectCompletionRateActual + "%";
                    
                    const delayEl = document.getElementById("kpiProjectDelayActual");
                    delayEl.innerText = data.projectDelayRateActual + "%";
                    if (data.projectDelayRateActual > 0) {
                        delayEl.className = "mb-0 text-danger font-extrabold";
                    } else {
                        delayEl.className = "mb-0 text-success font-extrabold";
                    }

                    document.getElementById("kpiTaskCompletionActual").innerText = data.taskCompletionRateActual + "%";
                    
                    const overdueEl = document.getElementById("kpiTaskOverdueActual");
                    overdueEl.innerText = data.overdueTaskRateActual + "%";
                    if (data.overdueTaskRateActual > 0) {
                        overdueEl.className = "mb-0 text-danger font-extrabold";
                    } else {
                        overdueEl.className = "mb-0 text-success font-extrabold";
                    }

                    document.getElementById("kpiMilestoneCompletionActual").innerText = data.milestoneCompletionRateActual + "%";
                    document.getElementById("kpiAvgProgressActual").innerText = data.averageProjectProgressActual + "%";
                    document.getElementById("kpiTripFulfillmentActual").innerText = data.tripFulfillmentRateActual + "%";
                    document.getElementById("kpiOnTimeDeliveryActual").innerText = data.onTimeTripDeliveryActual + "%";
                    document.getElementById("kpiFleetUtilizationActual").innerText = data.fleetUtilizationRateActual + "%";
                    document.getElementById("kpiResourceEfficiencyActual").innerText = data.resourceEfficiencyActual + "%";

                    // Render Charts
                    renderKpiCharts(data);
                }
            } catch (err) {
                console.error("Error loading project KPIs:", err);
            }
        }

        function renderKpiCharts(data) {
            if (chartProj) chartProj.destroy();
            if (chartTask) chartTask.destroy();
            if (chartMonthly) chartMonthly.destroy();
            if (chartFulfillment) chartFulfillment.destroy();

            const isAr = currentLang === 'ar';

            const statusLabelsMap = {
                "Active": isAr ? "نشط" : "Active",
                "Planning": isAr ? "تخطيط" : "Planning",
                "Completed": isAr ? "مكتمل" : "Completed",
                "On Hold": isAr ? "معلق" : "On Hold",
                "To Do": isAr ? "لم تبدأ" : "To Do",
                "In Progress": isAr ? "قيد التنفيذ" : "In Progress",
                "In Review": isAr ? "قيد المراجعة" : "In Review",
                "Done": isAr ? "مكتملة" : "Completed / Done"
            };

            // 1. Projects by Status
            const projCtx = document.getElementById('chartProjectsByStatus').getContext('2d');
            chartProj = new Chart(projCtx, {
                type: 'doughnut',
                data: {
                    labels: data.projectsByStatus.map(d => statusLabelsMap[d.label] || d.label),
                    datasets: [{
                        data: data.projectsByStatus.map(d => d.value),
                        backgroundColor: data.projectsByStatus.map(d => d.color || '#3b82f6'),
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom', labels: { color: '#e2e8f0', font: { size: 10 } } }
                    }
                }
            });

            // 2. Tasks by Status
            const taskCtx = document.getElementById('chartTasksByStatus').getContext('2d');
            chartTask = new Chart(taskCtx, {
                type: 'doughnut',
                data: {
                    labels: data.tasksByStatus.map(d => statusLabelsMap[d.label] || d.label),
                    datasets: [{
                        data: data.tasksByStatus.map(d => d.value),
                        backgroundColor: data.tasksByStatus.map(d => d.color || '#3b82f6'),
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom', labels: { color: '#e2e8f0', font: { size: 10 } } }
                    }
                }
            });

            // 3. Monthly Completed Tasks
            const monthlyCtx = document.getElementById('chartMonthlyTasks').getContext('2d');
            chartMonthly = new Chart(monthlyCtx, {
                type: 'bar',
                data: {
                    labels: data.monthlyTaskCompletion.map(d => d.label),
                    datasets: [{
                        label: isAr ? 'المهام المكتملة' : 'Completed Tasks',
                        data: data.monthlyTaskCompletion.map(d => d.value),
                        backgroundColor: '#10b981',
                        borderRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        x: { ticks: { color: '#94a3b8', font: { size: 10 } }, grid: { color: 'rgba(148,163,184,0.1)' } },
                        y: { ticks: { color: '#94a3b8', font: { size: 10 }, stepSize: 1 }, grid: { color: 'rgba(148,163,184,0.1)' } }
                    }
                }
            });

            // 4. Trip Fulfillment Rate per Project
            const fulfillmentCtx = document.getElementById('chartTripFulfillment').getContext('2d');
            chartFulfillment = new Chart(fulfillmentCtx, {
                type: 'bar',
                data: {
                    labels: data.tripFulfillmentPerProject.map(d => d.label),
                    datasets: [{
                        label: isAr ? 'نسبة الإنجاز %' : 'Fulfillment %',
                        data: data.tripFulfillmentPerProject.map(d => d.value),
                        backgroundColor: data.tripFulfillmentPerProject.map(d => d.color || '#b0841a'),
                        borderRadius: 6
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        x: { ticks: { color: '#94a3b8', font: { size: 10 } }, grid: { color: 'rgba(148,163,184,0.1)' }, max: 100 },
                        y: { ticks: { color: '#94a3b8', font: { size: 10 } }, grid: { color: 'rgba(148,163,184,0.1)' } }
                    }
                }
            });
        }
    </script>
}

